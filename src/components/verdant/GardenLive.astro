---
/**
 * GardenLive — a living hero. The real Garden UI (midnight-forest theme)
 * rebuilt in DOM and looped: net worth counts up, health bars grow with their
 * leaf tips, then it taps through Home → Money → Plan and back. No video file,
 * no screenshot — it's the compositor running, so it scales to any size with no
 * crop and stays crisp. Falls back to a calm static frame under reduced-motion.
 */
---

<div class="gl-phone" aria-hidden="true">
  <div class="gl-screen">
    <!-- the three beds live stacked; CSS cross-fades the active one -->
    <div class="gl-scenes">
      <!-- ── HOME ── -->
      <section class="gl-scene gl-home">
        <div class="gl-head">
          <span class="gl-label">Home</span>
          <span class="gl-serif gl-greet">Good evening.</span>
        </div>
        <div class="gl-net">
          <span class="gl-label">Net Worth</span>
          <div class="gl-serif gl-net-num" data-count="248120">$0</div>
          <div class="gl-mini-row">
            <span><i class="gl-label">Assets</i><b class="gl-serif" style="color:var(--gl-pos)">$291k</b></span>
            <span><i class="gl-label">Liabilities</i><b class="gl-serif" style="color:var(--gl-neg)">$43k</b></span>
            <span><i class="gl-label">Liquid</i><b class="gl-serif" style="color:var(--gl-t2)">$22k</b></span>
          </div>
        </div>
        <div class="gl-card">
          <div class="gl-card-head"><span class="gl-label">Health Score</span><span class="gl-serif" style="color:var(--gl-ac);font-size:22px">82<i style="font-size:10px;color:var(--gl-t3)"> / 100</i></span></div>
          <div class="gl-bars">
            <div class="gl-bar-row"><i class="gl-label">Savings</i><div class="gl-bar"><span style="--w:88%"></span></div></div>
            <div class="gl-bar-row"><i class="gl-label">Buffer</i><div class="gl-bar"><span style="--w:72%"></span></div></div>
            <div class="gl-bar-row"><i class="gl-label">Debt</i><div class="gl-bar"><span style="--w:64%"></span></div></div>
            <div class="gl-bar-row"><i class="gl-label">Discipline</i><div class="gl-bar"><span style="--w:80%"></span></div></div>
          </div>
        </div>
      </section>

      <!-- ── MONEY ── -->
      <section class="gl-scene gl-money">
        <div class="gl-head"><span class="gl-label">Money</span><span class="gl-serif gl-greet">This month</span></div>
        <div class="gl-card">
          <div class="gl-card-head"><span class="gl-label">Spent</span><span class="gl-serif" style="font-size:20px">$3,418</span></div>
          <div class="gl-bars">
            <div class="gl-bar-row"><i class="gl-label">Housing</i><div class="gl-bar"><span style="--w:54%"></span></div></div>
            <div class="gl-bar-row"><i class="gl-label">Food</i><div class="gl-bar"><span style="--w:38%"></span></div></div>
            <div class="gl-bar-row"><i class="gl-label">Transport</i><div class="gl-bar"><span style="--w:22%"></span></div></div>
          </div>
        </div>
        <div class="gl-card">
          <span class="gl-label">Quiet subscriptions</span>
          <div class="gl-sub"><span class="gl-serif">Streaming bundle</span><b class="gl-serif" style="color:var(--gl-neg)">−$47/mo</b></div>
          <div class="gl-sub"><span class="gl-serif">Unused gym</span><b class="gl-serif" style="color:var(--gl-neg)">−$31/mo</b></div>
          <div class="gl-sub gl-sub--note"><i class="gl-label">that's $936 a year</i></div>
        </div>
      </section>

      <!-- ── PLAN ── -->
      <section class="gl-scene gl-plan">
        <div class="gl-head"><span class="gl-label">Plan</span><span class="gl-serif gl-greet">Goals &amp; debt</span></div>
        <div class="gl-card gl-goal">
          <div class="gl-ring"><svg viewBox="0 0 80 80"><circle class="gl-ring-bg" cx="40" cy="40" r="34"/><circle class="gl-ring-fg" cx="40" cy="40" r="34"/></svg><div class="gl-ring-mid"><b class="gl-serif">64%</b></div></div>
          <div><span class="gl-serif" style="font-size:17px">Trip to Kyoto</span><div class="gl-label" style="margin-top:4px">$6,400 of $10,000 · Apr 2027</div></div>
        </div>
        <div class="gl-card">
          <div class="gl-card-head"><span class="gl-label">Debt-free in</span><span class="gl-serif" style="color:var(--gl-ac);font-size:18px">3 yr 2 mo</span></div>
          <div class="gl-bars"><div class="gl-bar-row"><i class="gl-label">Avalanche</i><div class="gl-bar"><span style="--w:46%"></span></div></div></div>
          <div class="gl-sub gl-sub--note"><i class="gl-label">$1,204 interest saved</i></div>
        </div>
      </section>
    </div>

    <!-- tab bar — the tap indicator rides across as scenes switch -->
    <nav class="gl-tabs">
      <span class="gl-tab" data-tab="home"><svg viewBox="0 0 24 24"><path d="M3 11l9-7 9 7v9H3z"/></svg>Home</span>
      <span class="gl-tab" data-tab="money"><svg viewBox="0 0 24 24"><path d="M4 19V5m0 14h16M8 16l4-5 3 3 5-7"/></svg>Money</span>
      <span class="gl-tab" data-tab="plan"><svg viewBox="0 0 24 24"><path d="M12 3v18M5 8l7-5 7 5"/></svg>Plan</span>
      <span class="gl-tap" aria-hidden="true"></span>
    </nav>
    <button class="gl-grove" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 21c0-6 0-9 0-12M12 13c0-5 4-8 9-8 0 5-4 8-9 8Z"/></svg></button>
  </div>
</div>

<style>
  .gl-phone{
    --gl-bg:#0f1411; --gl-surface:#161d18; --gl-line:#243029;
    --gl-t1:#e8efe9; --gl-t2:#aab8af; --gl-t3:#6f7d73;
    --gl-ac:#5fa777; --gl-gold:#c9a24b; --gl-pos:#6fbf8b; --gl-neg:#cf9270;
    --gl-serif:"Iowan Old Style",Palatino,Georgia,serif;
    --gl-mono:ui-monospace,"SF Mono",Menlo,monospace;
    position:relative; width:clamp(250px,30vw,330px); aspect-ratio:400/812;
    border-radius:42px; padding:10px;
    background:linear-gradient(160deg,#2a3b27 0%,#16271a 46%,#0a1610 100%);
    box-shadow:0 40px 90px -34px rgba(13,26,16,.6),0 0 0 1.5px rgba(255,255,255,.05),
      0 2px 0 rgba(255,255,255,.08) inset,0 -2px 8px rgba(0,0,0,.4) inset;
  }
  .gl-phone::after{content:"";position:absolute;top:14px;left:50%;transform:translateX(-50%);
    width:38%;height:7px;border-radius:5px;background:rgba(0,0,0,.5);z-index:5}
  .gl-screen{position:relative;width:100%;height:100%;border-radius:32px;overflow:hidden;
    background:var(--gl-bg);color:var(--gl-t1);font-family:var(--gl-serif)}
  .gl-scenes{position:absolute;inset:0}

  .gl-label{font-family:var(--gl-mono);font-size:8.5px;letter-spacing:.18em;text-transform:uppercase;
    color:var(--gl-t3);font-style:normal}
  .gl-serif{font-family:var(--gl-serif)}

  .gl-scene{position:absolute;inset:0;padding:42px 20px 76px;opacity:0;
    transform:translateX(14px);animation:gl-cycle 12s infinite}
  .gl-home{animation-delay:0s}.gl-money{animation-delay:4s}.gl-plan{animation-delay:8s}
  @keyframes gl-cycle{
    0%{opacity:0;transform:translateX(14px)}
    4%,29%{opacity:1;transform:translateX(0)}
    33%,100%{opacity:0;transform:translateX(-14px)}
  }

  .gl-head{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px}
  .gl-greet{font-size:19px;display:block;margin-top:5px;color:var(--gl-t1)}
  .gl-net-num{font-size:46px;margin:6px 0 12px;letter-spacing:-.01em}
  .gl-mini-row{display:flex;gap:14px}
  .gl-mini-row span{display:flex;flex-direction:column;gap:3px}
  .gl-mini-row b{font-size:15px}
  .gl-mini-row i{font-style:normal}

  .gl-card{background:var(--gl-surface);border:1px solid var(--gl-line);border-radius:18px;
    padding:14px 15px;margin-top:14px}
  .gl-card-head{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:12px}
  .gl-bars{display:flex;flex-direction:column;gap:9px}
  .gl-bar-row{display:flex;flex-direction:column;gap:4px}
  .gl-bar-row i{font-style:normal}
  .gl-bar{position:relative;height:7px;border-radius:999px;
    background:color-mix(in srgb,var(--gl-line) 70%,transparent);overflow:visible}
  .gl-bar span{position:absolute;left:0;top:0;height:100%;width:0;border-radius:999px;
    background:linear-gradient(90deg,color-mix(in srgb,var(--gl-ac) 55%,var(--gl-surface)),var(--gl-ac));
    animation:gl-grow 1.1s cubic-bezier(.16,1,.3,1) forwards;animation-delay:.4s}
  /* the living leaf tip at the leading edge */
  .gl-bar span::after{content:"";position:absolute;right:-1px;top:50%;width:9px;height:9px;
    border-radius:50% 50% 50% 0;transform:translateY(-50%) rotate(45deg);background:var(--gl-ac);
    box-shadow:0 0 0 2px color-mix(in srgb,var(--gl-surface) 80%,transparent)}
  @keyframes gl-grow{to{width:var(--w)}}

  .gl-sub{display:flex;justify-content:space-between;align-items:center;padding:8px 0;
    border-top:1px solid var(--gl-line);font-size:14px}
  .gl-sub--note{justify-content:flex-end}.gl-sub--note i{font-style:italic;color:var(--gl-gold)}

  .gl-goal{display:flex;align-items:center;gap:14px}
  .gl-ring{position:relative;width:60px;height:60px;flex:0 0 60px}
  .gl-ring svg{width:100%;height:100%;transform:rotate(-90deg)}
  .gl-ring circle{fill:none;stroke-width:6}
  .gl-ring-bg{stroke:var(--gl-line)}
  .gl-ring-fg{stroke:var(--gl-ac);stroke-linecap:round;stroke-dasharray:214;
    stroke-dashoffset:214;animation:gl-ring 1.3s cubic-bezier(.16,1,.3,1) forwards;animation-delay:8.3s}
  @keyframes gl-ring{to{stroke-dashoffset:77}}
  .gl-ring-mid{position:absolute;inset:0;display:grid;place-items:center}
  .gl-ring-mid b{font-size:15px;color:var(--gl-ac)}

  .gl-tabs{position:absolute;left:0;right:0;bottom:0;height:64px;display:flex;
    background:color-mix(in srgb,var(--gl-surface) 92%,transparent);
    border-top:1px solid var(--gl-line);backdrop-filter:blur(8px)}
  .gl-tab{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;
    font-family:var(--gl-mono);font-size:8px;letter-spacing:.12em;text-transform:uppercase;color:var(--gl-t3)}
  .gl-tab svg{width:19px;height:19px;fill:none;stroke:currentColor;stroke-width:1.6;
    stroke-linecap:round;stroke-linejoin:round}
  .gl-tab[data-tab="home"]{animation:gl-active 12s infinite;animation-delay:0s}
  .gl-tab[data-tab="money"]{animation:gl-active 12s infinite;animation-delay:4s}
  .gl-tab[data-tab="plan"]{animation:gl-active 12s infinite;animation-delay:8s}
  @keyframes gl-active{0%,33%{color:var(--gl-ac)}34%,100%{color:var(--gl-t3)}}
  /* tap pulse rides to each tab as it activates */
  .gl-tap{position:absolute;bottom:40px;width:36px;height:36px;border-radius:50%;
    background:radial-gradient(circle,color-mix(in srgb,var(--gl-ac) 40%,transparent),transparent 70%);
    left:calc(16.66% - 18px);animation:gl-tap 12s infinite}
  @keyframes gl-tap{
    0%,2%{left:calc(16.66% - 18px);opacity:0;transform:scale(.4)}
    4%{opacity:.9;transform:scale(1)}8%{opacity:0}
    33%{left:calc(16.66% - 18px)}34%{left:calc(50% - 18px);opacity:0;transform:scale(.4)}
    37%{opacity:.9;transform:scale(1)}41%{opacity:0}
    66%{left:calc(50% - 18px)}67%{left:calc(83.33% - 18px);opacity:0;transform:scale(.4)}
    70%{opacity:.9;transform:scale(1)}74%,100%{opacity:0}
  }

  .gl-grove{position:absolute;right:14px;bottom:78px;width:42px;height:42px;border-radius:50% 50% 50% 12px;
    border:none;background:linear-gradient(150deg,var(--gl-ac),#3c6e4f);display:grid;place-items:center;
    box-shadow:0 8px 20px -6px rgba(0,0,0,.6);animation:gl-float 4s ease-in-out infinite alternate}
  .gl-grove svg{width:20px;height:20px;fill:none;stroke:#0f1411;stroke-width:1.8;stroke-linecap:round}
  @keyframes gl-float{to{transform:translateY(-6px)}}

  @media(prefers-reduced-motion:reduce){
    .gl-scene,.gl-tab,.gl-tap,.gl-bar span,.gl-ring-fg,.gl-grove{animation:none}
    .gl-home{opacity:1;transform:none}.gl-money,.gl-plan,.gl-tap{display:none}
    .gl-bar span{width:var(--w)}.gl-ring-fg{stroke-dashoffset:77}
    .gl-tab[data-tab="home"]{color:var(--gl-ac)}
  }
</style>

<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const phone = document.querySelector('.gl-phone') as HTMLElement | null;

  if (phone && !reduce) {
    let countInterval: ReturnType<typeof setInterval> | null = null;

    const startCountUp = () => {
      document.querySelectorAll('.gl-net-num').forEach((el) => {
        const htmlEl = el as HTMLElement;
        const target = Number(htmlEl.dataset.count || '0');
        const fmt = (n: number) => '$' + Math.round(n).toLocaleString('en-US');
        const run = () => {
          const dur = 1100, t0 = performance.now();
          const tick = (now: number) => {
            const p = Math.min(1, (now - t0) / dur);
            const eased = 1 - Math.pow(1 - p, 3);
            htmlEl.textContent = fmt(target * eased);
            if (p < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        };
        run();
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            phone.style.animationPlayState = 'running';
            if (!countInterval) {
              startCountUp();
              countInterval = setInterval(startCountUp, 12000);
            }
          } else {
            phone.style.animationPlayState = 'paused';
            if (countInterval) {
              clearInterval(countInterval);
              countInterval = null;
            }
          }
        });
      },
      { threshold: 0.1 }
    );

    observer.observe(phone);
  }
</script>
