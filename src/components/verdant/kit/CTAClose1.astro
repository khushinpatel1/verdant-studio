---
/**
 * CTAClose1. "Editorial closer" (the default, shipped variant).
 * Left-aligned headline, a thin gold hairline rule, hairline .v-cta grammar
 * for both links (primary gets the seed-button treatment via v-cta--primary).
 * No green pigment blooms, no centered slab buttons. Replaces CTABand.
 */
interface Props {
  headline: string;
  sub?: string;
  cta: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
}

const { headline, sub, cta, ctaSecondary } = Astro.props;
---

<section class="v-cta1">
  <div class="v-cta1__rule"></div>
  <div class="v-cta1__row">
    <div class="v-cta1__copy">
      <h2 class="v-cta1__headline">{headline}</h2>
      {sub && <p class="v-cta1__sub">{sub}</p>}
    </div>
    <div class="v-cta1__ctas">
      <a href={cta.href} class="v-cta v-cta--primary">{cta.label}</a>
      {ctaSecondary && <a href={ctaSecondary.href} class="v-cta">{ctaSecondary.label}</a>}
    </div>
  </div>
</section>

<style>
  .v-cta1 {
    padding: clamp(3.5rem, 9vw, 6rem) var(--v-pad-h, clamp(20px, 5vw, 56px));
    max-width: var(--maxw);
    margin: 0 auto;
  }
  .v-cta1__rule {
    width: 100%;
    height: 1px;
    margin-bottom: clamp(2.5rem, 6vh, 4rem);
    background: linear-gradient(90deg, var(--gold), transparent 65%);
    opacity: 0.5;
  }
  .v-cta1__row {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: flex-start;
  }
  @media (min-width: 768px) {
    .v-cta1__row {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
      gap: 3rem;
    }
  }
  .v-cta1__copy { display: flex; flex-direction: column; gap: 0.85rem; }
  .v-cta1__headline {
    font-size: var(--text-3xl);
    color: var(--fg);
    line-height: 1.1;
    max-width: 22em;
  }
  .v-cta1__sub {
    font-size: var(--text-base);
    color: var(--muted);
    line-height: 1.6;
    max-width: 28em;
  }
  .v-cta1__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    align-items: center;
    flex: none;
  }
</style>
