---
interface Props {
  icon?: string;
  headline: string;
  blurb: string;
  link?: { label: string; href: string };
}

const { icon, headline, blurb, link } = Astro.props;
---

<div class="v-card">
  {icon && (
    <div class="v-card__icon">
      <img src={icon} alt="" />
    </div>
  )}
  <h3 class="v-card__headline">{headline}</h3>
  <p class="v-card__blurb">{blurb}</p>
  {link && (
    <a href={link.href} class="v-card__link">
      {link.label} →
    </a>
  )}
</div>

<style>
  .v-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: clamp(1.5rem, 4vw, 2rem);
    background: var(--card);
    border-radius: var(--radius);
    transition: all 200ms var(--ease-soft);
  }

  .v-card:hover {
    box-shadow: var(--sh-md);
    transform: translateY(-2px);
  }

  .v-card__icon {
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .v-card__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .v-card__headline {
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--fg);
    line-height: 1.2;
  }

  .v-card__blurb {
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: 1.6;
    flex-grow: 1;
  }

  .v-card__link {
    color: var(--green);
    text-decoration: none;
    font-size: var(--text-xs);
    font-weight: 500;
    align-self: flex-start;
    transition: all 200ms var(--ease-soft);
  }

  .v-card__link:hover {
    color: var(--green-600);
    transform: translateX(2px);
  }
</style>
