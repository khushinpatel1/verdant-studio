---
interface Props {
  align?: "left" | "right";
  headline: string;
  body: string;
  cta?: { label: string; href: string };
  media?: boolean;
  mediaSrc?: string;
  videoSrc?: string;
  product?: boolean;
  phone?: boolean;
}

const {
  align = "left",
  headline,
  body,
  cta,
  media = false,
  mediaSrc,
  videoSrc,
  product = false,
  phone = false
} = Astro.props;
---

<section class="v-feature-row" data-align={align}>
  <div class="v-feature-row__text">
    <h2 class="v-feature-row__headline">{headline}</h2>
    <p class="v-feature-row__body">{body}</p>
    {cta && (
      <a href={cta.href} class="v-feature-row__link">
        {cta.label}
      </a>
    )}
  </div>

  {media && (
    <div class="v-feature-row__media">
      {product && phone ? (
        <div class="v-phone-frame">
          <div class="v-phone-frame__screen">
            {videoSrc ? (
              <video
                src={videoSrc}
                muted
                loop
                playsinline
                preload="none"
                class="v-feature-row__video v-product-shot"
              />
            ) : mediaSrc ? (
              <img src={mediaSrc} alt="" class="v-feature-row__image v-product-shot" loading="lazy" decoding="async" />
            ) : null}
          </div>
        </div>
      ) : (
        <>
          {videoSrc ? (
            <video
              src={videoSrc}
              muted
              loop
              playsinline
              preload="metadata"
              class={`v-feature-row__video ${product ? "v-product-shot" : "v-bleed"}`}
            />
          ) : mediaSrc ? (
            <img src={mediaSrc} alt="" class={`v-feature-row__image ${product ? "v-product-shot" : "v-bleed"}`} loading="lazy" decoding="async" />
          ) : null}
        </>
      )}
    </div>
  )}
</section>

<style>
  .v-feature-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 8vw, 4rem);
    align-items: center;
    padding: clamp(2rem, 6vw, 4rem) var(--v-pad-h, clamp(20px, 5vw, 56px));
    max-width: var(--maxw);
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .v-feature-row {
      grid-template-columns: 1fr 1fr;
    }

    .v-feature-row[data-align="right"] {
      direction: rtl;
    }

    .v-feature-row[data-align="right"] > * {
      direction: ltr;
    }
  }

  .v-feature-row__text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .v-feature-row__headline {
    font-size: var(--text-3xl);
    color: var(--fg);
    line-height: 1.1;
  }

  .v-feature-row__body {
    font-size: var(--text-base);
    color: var(--muted);
    line-height: 1.7;
    max-width: 32em;
  }

  .v-feature-row__link {
    align-self: flex-start;
    color: var(--green);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 500;
    position: relative;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid var(--green);
    transition: all 200ms var(--ease-soft);
  }

  .v-feature-row__link:hover {
    color: var(--green-600);
    border-color: var(--green-600);
    padding-bottom: 0.5rem;
  }

  .v-feature-row__media {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .v-feature-row__image,
  .v-feature-row__video {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius);
  }

  .v-phone-frame {
    --rad: 42px;
    --pad: 10px;
    position: relative;
    width: clamp(220px, 60%, 300px);
    aspect-ratio: 400 / 812;
    margin: 0 auto;
    border-radius: var(--rad);
    padding: var(--pad);
    background: linear-gradient(160deg, #f0f2ed 0%, #e8ebe6 46%, #dfe4d7 100%);
    box-shadow: 0 40px 90px -24px rgba(13, 31, 7, 0.18), 0 0 0 1px rgba(47, 125, 79, 0.08),
      0 2px 0 rgba(255, 255, 255, 0.6) inset, 0 -2px 8px rgba(0, 0, 0, 0.06) inset;
  }

  .v-phone-frame::after {
    content: "";
    position: absolute;
    top: 14px;
    left: 50%;
    transform: translateX(-50%);
    width: 38%;
    height: 7px;
    border-radius: 5px;
    background: rgba(47, 125, 79, 0.2);
    z-index: 2;
  }

  .v-phone-frame__screen {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: calc(var(--rad) - var(--pad));
    background: var(--paper);
  }

  .v-phone-frame__screen .v-feature-row__image,
  .v-phone-frame__screen .v-feature-row__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 0;
    border-radius: 0;
  }
</style>
