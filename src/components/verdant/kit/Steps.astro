---
interface Step {
  number: string;
  headline: string;
  body: string;
}

interface Props {
  title?: string;
  steps: Step[];
}

const { title, steps } = Astro.props;
---

<section class="v-steps">
  {title && <h2 class="v-steps__title">{title}</h2>}
  <div class="v-steps__flow">
    {steps.map((step, idx) => (
      <div class="v-step">
        <div class="v-step__number">{step.number}</div>
        <h3 class="v-step__headline">{step.headline}</h3>
        <p class="v-step__body">{step.body}</p>
        {idx < steps.length - 1 && <div class="v-step__connector" />}
      </div>
    ))}
  </div>
</section>

<style>
  .v-steps {
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 6vw, 4rem);
    padding: clamp(2rem, 6vw, 4rem) var(--v-pad-h, clamp(20px, 5vw, 56px));
    max-width: var(--maxw);
    margin: 0 auto;
  }

  .v-steps__title {
    font-size: var(--text-3xl);
    color: var(--fg);
    line-height: 1.1;
  }

  .v-steps__flow {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
    gap: 2rem;
    position: relative;
  }

  @media (min-width: 768px) {
    .v-steps__flow {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .v-step {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
  }

  .v-step__number {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gold);
    font-weight: 500;
  }

  .v-step__headline {
    font-size: var(--text-lg);
    color: var(--fg);
    line-height: 1.2;
  }

  .v-step__body {
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: 1.6;
  }

  .v-step__connector {
    position: absolute;
    top: 50%;
    right: -1rem;
    width: 2rem;
    height: 1px;
    background: var(--line);
    transform: translateY(-50%);
  }

  @media (max-width: 767px) {
    .v-step__connector {
      display: none;
    }
  }

  @media (min-width: 768px) {
    .v-steps__flow > :last-child .v-step__connector {
      display: none;
    }
  }
</style>
