---
import "../styles/global.css";
import "../styles/verdant.css";
import { ClientRouter } from "astro:transitions";
import Cursor from "../components/verdant/Cursor";
import Nav from "../components/verdant/Nav";

interface Props { title: string; description?: string; image?: string }
const {
  title,
  description = "Verdant — a small, privacy-first software studio. Software grown for people, not advertisers.",
  image = "/og-image.jpg"
} = Astro.props;
const path = Astro.url.pathname.replace(/\/$/, "") || "/verdant";
const url = `https://verdant.studio${Astro.url.pathname}`;

const fonts = [
  "InstrumentSerif-Regular.woff2",
  "InstrumentSerif-Italic.woff2",
  "YoungSerif-Regular.woff2",
  "SchibstedGrotesk-Regular.woff2",
  "SchibstedGrotesk-Medium.woff2",
  "FragmentMono-Regular.woff2",
];
---

<!doctype html>
<html lang="en" data-skin="verdant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`https://verdant.studio${image}`} />
    <meta property="og:url" content={url} />
    <meta property="og:type" content="website" />

    <!-- Twitter/X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`https://verdant.studio${image}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    {fonts.map((f) => (
      <link rel="preload" href={`/fonts/verdant/${f}`} as="font" type="font/woff2" crossorigin />
    ))}
    <ClientRouter />
  </head>
  <body>
    <Cursor client:load transition:persist transition:persist-props />
    <Nav client:load path={path} />
    <main>
      <slot />
    </main>

    <script>
      import Lenis from "lenis";
      let lenis: any;
      function boot() {
        lenis?.destroy?.();
        // prefers-reduced-motion → native scroll, no smoothing layer at all
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) { lenis = null; return; }
        // coarse pointer (touch) → native scroll; Lenis on desktop/trackpad only
        if (window.matchMedia("(pointer: coarse)").matches) { lenis = null; return; }
        lenis = new Lenis({ lerp: 0.11, wheelMultiplier: 1 });
        function raf(t: number) { lenis?.raf(t); requestAnimationFrame(raf); }
        requestAnimationFrame(raf);
      }

      // scroll-reveal driver — re-armed on every view transition
      let io: IntersectionObserver | null = null;
      function arm() {
        io?.disconnect();
        const els = Array.from(document.querySelectorAll<HTMLElement>("[data-v-reveal]"));
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          els.forEach((el) => el.classList.add("in"));
          return;
        }
        io = new IntersectionObserver(
          (entries) => entries.forEach((e) => {
            if (e.isIntersecting) { e.target.classList.add("in"); io!.unobserve(e.target); }
          }),
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
        );
        els.forEach((el) => io!.observe(el));
      }

      document.addEventListener("astro:page-load", () => { boot(); arm(); });
    </script>
  </body>
</html>
