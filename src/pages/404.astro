---
import "../styles/global.css";
import "../styles/verdant.css";
import Moon from "../components/verdant/ink/Moon";
import MountainRidge from "../components/verdant/ink/MountainRidge";
import MistLayer from "../components/verdant/ink/MistLayer";

const title = "Not found";
const description = "This page doesn't exist.";
---

<!doctype html>
<html lang="en" data-skin="verdant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      body {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        background: var(--paper);
        color: var(--ink);
        margin: 0;
        padding: clamp(20px, 4vh, 40px);
        position: relative;
      }

      .v404-hero {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        max-width: 560px;
        z-index: 2;
        position: relative;
      }

      h1 {
        font-family: var(--font-display);
        font-size: clamp(4.5rem, 12vw, 8rem);
        color: var(--leaf);
        margin: 0 0 1rem;
        line-height: 1.0;
      }

      .v404-desc {
        font-family: var(--font-body);
        font-size: var(--text-lg);
        color: var(--ink-soft);
        margin: 0 0 2.2rem;
        line-height: 1.65;
        max-width: 54ch;
      }

      .v404-cta {
        display: inline-flex;
        color: var(--ink);
      }

      .vh-404-accent {
        position: absolute;
        top: clamp(40px, 8vh, 80px);
        right: clamp(20px, 4vw, 60px);
        width: clamp(100px, 16vw, 160px);
        height: auto;
        aspect-ratio: 240 / 260;
        opacity: 0.18;
        pointer-events: none;
        z-index: 1;
      }

      .vh-404-band {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        height: clamp(60px, 10vh, 140px);
        pointer-events: none;
        overflow: hidden;
        z-index: 1;
      }

      .vh-404-mountain, .vh-404-mist {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
      }

      .vh-404-mountain {
        color: var(--moss);
        opacity: 0.35;
      }

      .vh-404-mist {
        color: var(--sage);
        opacity: 0.45;
      }

      @media (max-width: 640px) {
        .vh-404-accent {
          width: clamp(80px, 14vw, 120px);
          top: clamp(30px, 6vh, 50px);
          right: clamp(15px, 3vw, 30px);
        }
      }
    </style>
  </head>
  <body>
    <!-- P2: Moon accent in top-right corner -->
    <div class="vh-404-accent" aria-hidden="true">
      <Moon client:visible />
    </div>

    <div class="v404-hero">
      <div>
        <h1>404</h1>
        <p class="v404-desc">This page doesn't exist. The garden grows, but not everywhere yet.</p>
        <a href="/verdant" class="v-cta v404-cta">Back to Verdant</a>
      </div>
    </div>

    <!-- P2: Mountain/Mist band at bottom -->
    <div class="vh-404-band" aria-hidden="true">
      <div class="vh-404-mountain">
        <MountainRidge client:visible />
      </div>
      <div class="vh-404-mist">
        <MistLayer client:visible />
      </div>
    </div>
  </body>
</html>
