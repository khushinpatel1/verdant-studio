---
import "../styles/global.css";
import "../styles/verdant.css";

const title = "Not found";
const description = "This page doesn't exist.";
---

<!doctype html>
<html lang="en" data-skin="verdant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      body {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        background: var(--paper);
        color: var(--ink);
        margin: 0;
        padding: 20px;
      }
      .container {
        max-width: 560px;
        text-align: center;
      }
      h1 {
        font-family: var(--font-display);
        font-size: clamp(4.5rem, 12vw, 8rem);
        margin: 0 0 16px;
        color: var(--leaf);
      }
      p {
        font-family: var(--font-body);
        font-size: 1.05rem;
        color: var(--ink-soft);
        margin: 0 0 28px;
        line-height: 1.6;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>404</h1>
      <p>This page doesn't exist. The garden grows, but not everywhere yet.</p>
      <a href="/verdant" class="v-cta v-cta--primary">Back to Verdant</a>
    </div>
  </body>
</html>
