---
import "../styles/global.css";
import "../styles/verdant.css";
import Moon from "../components/verdant/ink/Moon";
import MountainRidge from "../components/verdant/ink/MountainRidge";
import MistLayer from "../components/verdant/ink/MistLayer";

const title = "Not found";
const description = "This page doesn't exist.";
---

<!doctype html>
<html lang="en" data-skin="verdant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      body {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        background: var(--paper);
        color: var(--ink);
        margin: 0;
        padding: 20px;
      }
      .container {
        max-width: 560px;
        text-align: center;
      }
      h1 {
        font-family: var(--font-display);
        font-size: clamp(4.5rem, 12vw, 8rem);
        margin: 0 0 16px;
        color: var(--leaf);
      }
      p {
        font-family: var(--font-body);
        font-size: 1.05rem;
        color: var(--ink-soft);
        margin: 0 0 28px;
        line-height: 1.6;
      }
      .vh-404-accent {
        position: absolute;
        top: 60px;
        right: 40px;
        width: 120px;
        height: 120px;
        opacity: 0.25;
        pointer-events: none;
      }
      .vh-404-band {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        height: clamp(60px, 10vh, 140px);
        pointer-events: none;
        overflow: hidden;
      }
      .vh-404-mountain, .vh-404-mist {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
      }
      .vh-404-mountain {
        color: var(--moss);
        opacity: 0.35;
      }
      .vh-404-mist {
        color: var(--sage);
        opacity: 0.45;
      }
    </style>
  </head>
  <body>
    <!-- P2: Moon accent in top-right corner -->
    <div class="vh-404-accent" aria-hidden="true">
      <Moon client:visible />
    </div>
    <div class="container">
      <h1>404</h1>
      <p>This page doesn't exist. The garden grows, but not everywhere yet.</p>
      <a href="/verdant" class="v-cta v-cta--primary">Back to Verdant</a>
    </div>
    <!-- P2: Mountain/Mist band at bottom -->
    <div class="vh-404-band" aria-hidden="true">
      <div class="vh-404-mountain">
        <MountainRidge client:visible />
      </div>
      <div class="vh-404-mist">
        <MistLayer client:visible />
      </div>
    </div>
  </body>
</html>
