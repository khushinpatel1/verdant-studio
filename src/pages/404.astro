---
import "../styles/global.css";
import "../styles/verdant.css";

const title = "Not found";
const description = "This page doesn't exist.";
---

<!doctype html>
<html lang="en" data-skin="verdant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      body {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        background: var(--paper);
        color: var(--ink);
        margin: 0;
        padding: clamp(20px, 4vh, 40px);
        position: relative;
      }

      .v404-hero {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        max-width: 560px;
        z-index: 2;
        position: relative;
      }

      h1 {
        font-family: var(--font-display);
        font-size: clamp(4.5rem, 12vw, 8rem);
        color: var(--leaf);
        margin: 0 0 1rem;
        line-height: 1.0;
      }

      .v404-desc {
        font-family: var(--font-body);
        font-size: var(--text-lg);
        color: var(--ink-soft);
        margin: 0 0 2.2rem;
        line-height: 1.65;
        max-width: 54ch;
      }

      .v404-cta {
        display: inline-flex;
        color: var(--ink);
      }

    </style>
  </head>
  <body>
    <div class="v404-hero">
      <div>
        <h1>404</h1>
        <p class="v404-desc">This page doesn't exist. Check the nav or head back home.</p>
        <a href="/verdant" class="v-cta v404-cta">Back to Verdant</a>
      </div>
    </div>
  </body>
</html>
