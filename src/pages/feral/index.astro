---
import Feral from "../../layouts/Feral.astro";
import VarHero from "../../components/feral/VarHero";
import VelocityMarquee from "../../components/feral/VelocityMarquee";
import TextReveal from "../../components/feral/TextReveal";
import Footer from "../../components/feral/Footer";
import { projects } from "../../data/projects";
import DisplaceImage from "../../components/feral/DisplaceImage";

const featured = projects.slice(0, 2);
---

<Feral title="FERAL — design & motion studio">
  <VarHero
    client:load
    label="Independent design & motion / Est. 2021"
    lines={["We make", "websites that", "behave like", "objects."]}
    sub="A small studio for brands that would rather be felt than scrolled past. Four people, no account managers, one cobalt accent."
  />

  <VelocityMarquee client:visible text="Identity" />

  <section style="padding: clamp(80px,16vh,200px) 0;">
    <div class="f-wrap" style="display:grid; grid-template-columns: 1fr; gap: 0;">
      <TextReveal
        client:visible
        as="h2"
        className="f-display"
        style={{ fontSize: "clamp(28px,5vw,68px)", fontWeight: 360, maxWidth: "16ch" }}
        lines={["We don't sell", "templates. We", "build the few", "moments a visitor", "actually remembers."]}
      />
      <p style="margin-top: 48px; margin-left:auto; max-width: 46ch; color: var(--muted); font-size:18px; line-height:1.6;">
        Most of a site is plumbing. We spend our budget where attention lands: the
        first three seconds, the one interaction worth screenshotting, the way it
        feels to leave. Everything else, we keep quiet and fast.
      </p>
    </div>
  </section>

  <section style="padding-bottom: clamp(80px,14vh,180px);">
    <div class="f-wrap">
      <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:40px;">
        <p class="f-label"><b>◍</b> Selected work</p>
        <a href="/feral/work" class="f-label f-link" data-cursor="All work" style="color:var(--fg);">All four →</a>
      </div>
      <div style="display:grid; grid-template-columns: repeat(2, 1fr); gap: clamp(20px,4vw,56px);">
        {featured.map((p, i) => (
          <a href={`/feral/work/${p.slug}`} data-cursor="View" class="f-link" style={`margin-top:${i === 1 ? "clamp(40px,10vw,160px)" : "0"};`}>
            <DisplaceImage client:visible src={p.cover} alt={p.title} style={{ aspectRatio: "4/3", borderRadius: "var(--radius)", border: "1px solid var(--line)" }} />
            <div style="display:flex; justify-content:space-between; align-items:baseline; margin-top:16px; gap:16px;">
              <h3 class="f-display" style="font-size:clamp(20px,2.4vw,32px); font-weight:400;">{p.title}</h3>
              <span class="f-label">{p.idx}</span>
            </div>
            <p class="f-label" style="margin-top:8px;">{p.client} · {p.year}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer client:visible />
</Feral>
