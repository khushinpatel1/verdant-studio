---
import Feral from "../../../layouts/Feral.astro";
import WorkGrid from "../../../components/feral/WorkGrid";
import Footer from "../../../components/feral/Footer";
import TextReveal from "../../../components/feral/TextReveal";
---

<Feral title="Work — FERAL">
  <section style="padding-top: clamp(140px,22vh,300px); padding-bottom: clamp(20px,4vh,40px);">
    <div class="f-wrap">
      <p class="f-label" style="margin-bottom:32px;"><b>◍</b> Four we're proud of</p>
      <TextReveal
        client:load
        as="h2"
        className="f-display"
        style={{ fontSize: "clamp(40px,9vw,140px)", fontWeight: 340, letterSpacing: "-0.02em" }}
        lines={["Work, not", "portfolio."]}
      />
      <p style="margin-top:36px; max-width: 50ch; color:var(--muted); font-size:18px; line-height:1.6;">
        We take on a handful of projects a year so each one gets the studio, not a
        junior. Hover a piece. The image warps because we built it to — same
        technique that ships on every site below.
      </p>
    </div>
  </section>

  <WorkGrid client:visible />
  <Footer client:visible />
</Feral>
