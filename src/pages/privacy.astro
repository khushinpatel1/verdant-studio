---
import Verdant from "../layouts/Verdant.astro";
import Footer from "../components/verdant/Footer";
---

<Verdant title="Privacy Policy — Verdant">
  <main style="max-width: 48rem; margin: 0 auto; padding: clamp(3rem, 8vw, 5rem) clamp(20px, 5vw, 56px);">
    <h1 style="font-size: var(--text-3xl); color: var(--fg); margin-bottom: 2rem;">Privacy Policy</h1>

    <div style="display: flex; flex-direction: column; gap: 2rem; font-size: var(--text-base); line-height: 1.7; color: var(--muted);">
      <section>
        <h2 style="font-size: var(--text-xl); color: var(--fg); margin-bottom: 1rem;">Garden App</h2>
        <p>Your financial data is encrypted on your device before it ever leaves. The Verdant server holds only ciphertext. We cannot read your numbers.</p>
        <p>Garden works offline. Your data stays yours, always.</p>
      </section>

      <section>
        <h2 style="font-size: var(--text-xl); color: var(--fg); margin-bottom: 1rem;">What we collect</h2>
        <p>We collect the minimum needed to run the app: your account structure, encrypted transaction data, and anonymized usage patterns (app crashes, feature usage).</p>
        <p>We do not collect:</p>
        <ul style="margin: 1rem 0 0 1.5rem; list-style: inside;">
          <li>Your location</li>
          <li>Your browsing history</li>
          <li>Your contacts or device identifiers</li>
          <li>Data for advertising or tracking</li>
        </ul>
      </section>

      <section>
        <h2 style="font-size: var(--text-xl); color: var(--fg); margin-bottom: 1rem;">Data you control</h2>
        <p>You can export, delete, or reset your entire garden at any time. No waiting period. No recovery. It's gone.</p>
      </section>

      <section>
        <h2 style="font-size: var(--text-xl); color: var(--fg); margin-bottom: 1rem;">Questions?</h2>
        <p>Email us at <a href="mailto:verdantmail@proton.me" style="color: var(--green); text-decoration: underline;">verdantmail@proton.me</a></p>
      </section>
    </div>
  </main>

  <Footer client:visible />
</Verdant>
