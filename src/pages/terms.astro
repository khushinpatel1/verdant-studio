---
import Verdant from "../layouts/Verdant.astro";
import Footer from "../components/verdant/Footer";
---

<Verdant title="Terms of Service — Verdant" description="Verdant Studio terms of service">
  <!-- ── HERO — Simple, left-pinned ── -->
  <section class="ve-hero">
    <div class="v-wrap ve-hero-inner">
      <p class="v-label">Legal</p>
      <h1 class="v-display ve-hero-head">
        Terms of <span style="color: var(--leaf);">Service</span>.
      </h1>
      <p class="ve-hero-sub">
        Last updated June 2026. Covers your use of Garden and Verdant Studio products.
      </p>
    </div>
  </section>

  <!-- ── TERMS CONTENT ── -->
  <section class="ve-terms-section ve-sec">
    <span class="vh-num" aria-hidden="true">01</span>
    <div class="ve-terms-content">
      <h2>1. Agreement to Terms</h2>
      <p>
        By using Garden or any Verdant Studio service, you agree to these terms. If you do not agree, do not use our services.
      </p>

      <h2>2. Beta Terms</h2>
      <p>
        Garden is in beta. The service, features, and pricing may change at any time. Beta is provided "as is" without warranty. We're building it openly and ask for your patience.
      </p>

      <h2>3. Your Data</h2>
      <p>
        Your financial data is yours. We do not sell, trade, or share your data. You may export or delete your data at any time. See our <a href="/privacy">privacy policy</a> for details on what we store and how we protect it.
      </p>

      <h2>4. Acceptable Use</h2>
      <p>
        You agree not to use Garden for illegal purposes, to harass others, or to violate any applicable law. Do not attempt to reverse-engineer, hack, or disrupt the service.
      </p>

      <h2>5. Limitation of Liability</h2>
      <p>
        To the fullest extent permitted by law, Verdant Studio is not liable for any indirect, incidental, special, or consequential damages. Use Garden at your own risk.
      </p>

      <h2>6. Termination</h2>
      <p>
        We reserve the right to suspend or terminate access if you violate these terms. You may close your account at any time. Upon termination, your data remains yours and is exportable.
      </p>

      <h2>7. Changes to Terms</h2>
      <p>
        We may update these terms at any time. We'll notify you of material changes. Continued use means acceptance.
      </p>

      <h2>8. Contact</h2>
      <p>
        Questions? <a href="mailto:verdantmail@proton.me">Email us</a>.
      </p>

      <p style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--line); color: var(--moss); font-size: var(--text-sm);">
        Verdant Studio—independent, privacy-first software.
      </p>
    </div>
  </section>

  <Footer client:visible />
</Verdant>

<style is:global>
  /* ── Terms section ── */
  .ve-terms-section { background: var(--paper-soft); padding-block: clamp(110px, 18vh, 220px); }
  .ve-terms-content { grid-column: 2 / 11; }
  .ve-terms-content h2 { font-family: var(--font-display); font-size: var(--text-xl); color: var(--ink); line-height: 1.3; margin: 2rem 0 0.8rem 0; font-weight: 400; }
  .ve-terms-content h2:first-child { margin-top: 0; }
  .ve-terms-content p { font-size: var(--text-lg); line-height: 1.7; color: var(--ink-soft); max-width: 70ch; margin-bottom: 1.6rem; }
  .ve-terms-content a { color: var(--leaf); text-decoration: none; }
  .ve-terms-content a:hover { text-decoration: underline; }

  /* ── Responsive ── */
  @media (max-width: 860px) {
    .ve-hero-bg { display: none; }
    .ve-hero-inner { grid-column: 1 / 13; }
    .ve-terms-content { grid-column: 1 / 13; }
  }
</style>
