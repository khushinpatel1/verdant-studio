---
import Verdant from "../../layouts/Verdant.astro";
import Footer from "../../components/verdant/Footer";
import Hero from "../../components/verdant/kit/Hero.astro";
import Steps from "../../components/verdant/kit/Steps.astro";
import CardGrid from "../../components/verdant/kit/CardGrid.astro";
import Card from "../../components/verdant/kit/Card.astro";
import CTABand from "../../components/verdant/kit/CTABand.astro";
---

<Verdant title="Join the Beta — Garden" description="Early access to Garden. Free forever for beta testers.">
  <Hero
    headline="Join the beta"
    sub="Early access to Garden. Test it, break it, tell us what you think. You keep access forever."
    cta1={{ label: "Get started", href: "https://garden.khushinpatel1.workers.dev" }}
  />

  <Steps
    title="How to join"
    steps={[
      { number: "01", headline: "Create an account", body: "Sign up at the app. No credit card needed." },
      { number: "02", headline: "Add your accounts", body: "Manual entry or import statements. Both work now." },
      { number: "03", headline: "Start exploring", body: "See your numbers. Keep them private." }
    ]}
  />

  <CardGrid cols={3} title="Ready now">
    <Card headline="Net worth tracking" blurb="All your accounts in one place." />
    <Card headline="Money management" blurb="Spending, budgets, and categories." />
    <Card headline="Grove assistant" blurb="AI that works on your device only." />
  </CardGrid>

  <CTABand
    headline="Ready to begin?"
    sub="Your financial life, kept private."
    cta={{ label: "Join the beta", href: "https://garden.khushinpatel1.workers.dev" }}
  />

  <Footer client:visible />
</Verdant>
