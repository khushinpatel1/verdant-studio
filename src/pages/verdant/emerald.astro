---
import Verdant from "../../layouts/Verdant.astro";
import EmeraldNight from "../../components/verdant/EmeraldNight";
import { emerald, brand } from "../../data/verdant";
---

<Verdant title="Emerald — Verdant" image="/og/og-emerald.jpg">
  <div class="vem-bg" aria-hidden></div>
  <EmeraldNight client:load className="v-field-bg" />

  <section class="vem">
    <div class="v-wrap vem-inner">
      <img class="vem-art" src={emerald.cover} alt="" aria-hidden />
      <p class="v-label vem-kind">{emerald.kind}</p>
      <h1 class="v-display vem-name">Emerald</h1>
      <p class="vem-line v-display">{emerald.oneLine}</p>
      <p class="vem-blurb">{emerald.blurb}</p>
      <a href="/verdant" class="v-cta v-cta--light vem-back" data-cursor="Leave">Back to the garden</a>
      <p class="vem-foot">{brand.email}</p>
    </div>
  </section>
</Verdant>

<style is:global>
  .vem-bg { position: fixed; inset: 0; z-index: -2;
    background:
      radial-gradient(80% 70% at 72% 18%, rgba(60,107,30,0.4), transparent 60%),
      radial-gradient(70% 80% at 10% 100%, rgba(13,31,7,0.7), transparent 55%),
      linear-gradient(160deg, var(--forest-900) 0%, var(--forest) 55%, #0a1606 100%); }
  .vem { position: relative; z-index: 1; min-height: 100svh; display: flex; align-items: center; overflow: hidden; }
  .vem-field { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .vem-inner { position: relative; max-width: 60ch; padding: 8rem 0; }
  .vem-art { position: absolute; right: -8%; top: 50%; transform: translateY(-50%); width: clamp(280px, 38vw, 540px); z-index: -1;
    opacity: 0.32; filter: saturate(0.7) brightness(0.9);
    -webkit-mask-image: radial-gradient(70% 70% at 60% 50%, #000 8%, transparent 72%);
            mask-image: radial-gradient(70% 70% at 60% 50%, #000 8%, transparent 72%); }
  .vem-kind { color: var(--moss-300); }
  .vem-name { font-size: clamp(4rem, 13vw, 11rem); color: var(--moon); line-height: 0.9; margin: 1.5rem 0 1.5rem;
    text-shadow: 0 0 50px rgba(95,174,126,0.35); }
  .vem-name::after { content: ""; display: inline-block; width: 0.22em; height: 0.22em; margin-left: 0.18em; vertical-align: 0.1em;
    border-radius: 60% 40% 55% 45% / 50% 60% 40% 50%;
    background: radial-gradient(circle at 35% 30%, #7fe0a8, #1f8b4a 65%, #0e5a30);
    box-shadow: 0 0 24px rgba(95,174,126,0.7); }
  .vem-line { font-size: clamp(1.4rem, 2.6vw, 2.2rem); color: var(--sage); max-width: 24ch; }
  .vem-blurb { color: var(--moss-300); line-height: 1.75; max-width: 50ch; margin: 1.8rem 0 2.6rem; }
  .vem-back { color: var(--moon); }
  .vem-foot { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.14em; text-transform: uppercase;
    color: rgba(200,213,185,0.4); margin-top: 4rem; }
</style>
