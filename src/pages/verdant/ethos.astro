---
import Verdant from "../../layouts/Verdant.astro";
import Footer from "../../components/verdant/Footer";
import Hero from "../../components/verdant/kit/Hero.astro";
import FeatureRow from "../../components/verdant/kit/FeatureRow.astro";
import Steps from "../../components/verdant/kit/Steps.astro";
import CTABand from "../../components/verdant/kit/CTABand.astro";
import { ethos } from "../../data/verdant";
---

<Verdant title="Ethos — What Verdant believes" description="A quiet kind of conviction about how software should work.">
  <Hero
    headline="A quiet kind of conviction"
    sub="Built as a refusal of the industry it came from — software that earns a living without watching the person using it."
    cta1={{ label: "Try Garden", href: "https://garden.khushinpatel1.workers.dev" }}
    media={true}
    mediaSrc="/verdant/media/crane.jpg"
  />

  <div style="padding: clamp(3rem, 8vw, 5rem) clamp(20px, 5vw, 56px); max-width: var(--maxw); margin: 0 auto;">
    <div style="display: grid; gap: 2rem;">
      {ethos.creed.map((line) => (
        <div style="border-top: 1px solid var(--line); padding-top: 1.5rem; font-size: var(--text-lg); line-height: 1.6; color: var(--fg);">
          {line}
        </div>
      ))}
    </div>
  </div>

  <FeatureRow
    align="left"
    headline="Why this exists"
    body="Most apps work for a model that wasn't yours to begin with — extract value, not build it. We built Verdant for the opposite: it works for you, kept private by architecture, never by promise."
    media={true}
    mediaSrc="/verdant/art/ethos-sand.jpg"
  />

  <FeatureRow
    align="right"
    headline="How we keep it"
    body="Code you can read. A security audit you can check. No dark patterns. No dark mode for the business model. We're accountable to you, not an algorithm."
    media={true}
    mediaSrc="/verdant/media/koi.jpg"
  />

  <Steps
    title="Our Three Laws"
    steps={[
      { number: "01", headline: "Your data is yours", body: "Encrypted on your device. The server holds only ciphertext." },
      { number: "02", headline: "No ads, no tracking", body: "You're the customer, never the product. Full stop." },
      { number: "03", headline: "Built in the open", body: "Code, security, privacy — auditable, explained, real." }
    ]}
  />

  <CTABand
    headline="Let's talk"
    sub="Questions, feedback, or just thoughts?"
    cta={{ label: "Email us", href: "mailto:verdantmail@proton.me" }}
  />

  <Footer client:visible />
</Verdant>
