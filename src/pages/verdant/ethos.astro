---
import Verdant from "../../layouts/Verdant.astro";
import InkGrowth from "../../components/verdant/InkGrowth";
import Footer from "../../components/verdant/Footer";
import { brand, ethos } from "../../data/verdant";
---

<Verdant title="Ethos — Verdant" image="/og/og-ethos.jpg">
  <!-- ── HERO — Luminous, asymmetric. Text left, soft field right. ── -->
  <section class="ve-hero">
    <div class="ve-hero-bg" aria-hidden="true"></div>
    <div class="v-wrap ve-hero-inner">
      <p class="v-label">What holds.</p>
      <h1 class="v-display ve-hero-head">
        A quiet kind<br />of <span style="color: var(--leaf);">conviction</span>.
      </h1>
      <p class="ve-hero-sub">
        Built as a refusal of the industry it came from — software that earns a
        living without watching the person using it.
      </p>
    </div>
  </section>

  <!-- ── CREED — asymmetric grid, off-axis ── -->
  <section class="ve-creed ve-sec">
    <span class="vh-num" aria-hidden="true">01</span>
    {ethos.creed.map((line, i) => (
      <div class={`ve-creed-row${i % 2 ? " ve-creed-row--alt" : ""}`} data-v-reveal style={`--d:${i * 0.05}s`}>
        <span class="v-label v-label--bare">0{i + 1}</span>
        <p class="v-display ve-creed-text">{line}</p>
      </div>
    ))}
  </section>

  <!-- ── STORY — light image, off-axis, vine accent ── -->
  <section class="ve-story ve-sec">
    <span class="vh-num" aria-hidden="true">02</span>
    <div class="ve-story-media" data-v-reveal>
      <img src="/verdant/art/ethos-sand.jpg" alt="Raked sand" loading="lazy" decoding="async" />
      <InkGrowth client:visible side="right" className="ve-story-vine" />
    </div>
    <div class="ve-story-text">
      <p class="v-label" data-v-reveal>Why this exists</p>
      <p data-v-reveal>
        Verdant started from one stubborn opinion: that software can earn a
        living without selling the person using it. The whole industry seems to
        run the other way — free, because you're the product. This is the refusal
        of that.
      </p>
      <p data-v-reveal>
        So it stays small on purpose. One person, modern tools, no investors to
        answer to and no growth target pulling it toward something it would have
        to apologise for. A few things, made well, finished.
      </p>
      <p data-v-reveal>
        The Japanese garden is the standing reference. Composed, unhurried,
        alive underneath — nothing extra, everything placed on purpose. When a
        decision is hard, the test is whether it would belong in one.
      </p>
    </div>
  </section>

  <!-- ── TALK — luminous CTA band, left-pinned ── -->
  <section id="talk" class="ve-talk ve-sec">
    <span class="vh-num" aria-hidden="true">03</span>
    <h2 class="v-display ve-talk-head">Tell us what<br />you're <span style="color: var(--leaf);">building</span>.</h2>
    <a href={`mailto:${brand.email}`} class="v-cta">{brand.email}</a>
    <p class="v-label ve-talk-meta">Verdant — independent, privacy-first</p>
  </section>

  <Footer client:visible />
</Verdant>

<style is:global>
  /* ── Off-axis editorial grid (matching homepage) ── */
  .ve-sec {
    position: relative;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    column-gap: clamp(12px, 1.6vw, 28px);
    padding-inline: clamp(20px, 5vw, 72px);
  }

  /* ── HERO — asymmetric, text left + soft light field ── */
  .ve-hero { min-height: 100svh; align-content: center; overflow: hidden; background: var(--paper); padding-block: 6rem 2rem; }
  .ve-hero-bg { position: absolute; top: 0; right: 0; bottom: 0; width: 45%;
    background: linear-gradient(135deg, var(--mist) 0%, var(--dawn) 100%);
    opacity: 0.6; pointer-events: none; }
  .ve-hero-inner { grid-column: 1 / 8; position: relative; z-index: 1; }
  .ve-hero-head { font-size: var(--display-1); color: var(--ink); margin-top: 2.4rem; line-height: 1.05; }
  .ve-hero-sub { font-family: var(--font-display); font-size: var(--text-xl); line-height: 1.55; color: var(--ink); max-width: 38ch; margin-top: 2rem; }

  /* ── CREED — asymmetric grid, off-axis rows ── */
  .ve-creed { background: var(--paper-soft); padding-block: clamp(90px, 16vh, 220px); row-gap: 2.4rem; }
  .ve-creed-row { grid-column: 2 / 11; padding: clamp(1.8rem, 3vh, 2.8rem) 0; border-top: 1px solid var(--line); }
  .ve-creed-row--alt { grid-column: 6 / 12; }
  .ve-creed-text { font-family: var(--font-display); font-size: var(--text-xl); color: var(--ink); line-height: 1.4; max-width: 30ch; }

  /* ── STORY — off-axis, image left with vine, text right ── */
  .ve-story { background: var(--paper); padding-block: clamp(110px, 18vh, 260px); }
  .ve-story-media { grid-column: 1 / 7; position: relative; }
  .ve-story-media img { width: 100%; aspect-ratio: 3/4; object-fit: cover; border-radius: 4px; }
  .ve-story-vine { position: absolute; right: -60px; top: 8%; width: 130px; height: 300px; opacity: 0.75; }
  .ve-story-text { grid-column: 7 / 13; display: flex; flex-direction: column; gap: 1.6rem; padding-top: 2rem; }
  .ve-story-text p:not(.v-label) { font-size: var(--text-lg); line-height: 1.7; color: var(--ink-soft); max-width: 50ch; }

  /* ── TALK — luminous left-pinned CTA ── */
  .ve-talk { background: var(--paper); padding-block: clamp(120px, 20vh, 220px); align-content: center; }
  .ve-talk-head { grid-column: 1 / 9; font-size: var(--display-1); color: var(--ink); line-height: 1.05; }
  .ve-talk-head + .v-cta { grid-column: 1 / 9; margin-top: 2rem; }
  .ve-talk-meta { grid-column: 1 / 9; margin-top: 1.2rem; }

  /* ── Section numerals ── */
  .vh-num {
    position: absolute; top: clamp(2rem, 5vh, 4rem); left: clamp(20px, 5vw, 72px);
    font-family: var(--font-mono); font-size: var(--text-2xs);
    letter-spacing: 0.2em; color: var(--moss); opacity: 0.7;
  }
  .vh-num::after { content: ""; display: inline-block; width: 2.2rem; height: 1px;
    background: var(--sage); vertical-align: middle; margin-left: 0.7rem; }

  /* ── Responsive ── */
  @media (max-width: 860px) {
    .ve-hero-bg { display: none; }
    .ve-hero-inner { grid-column: 1 / 13; }
    .ve-creed-row { grid-column: 1 / 13; }
    .ve-story-media { grid-column: 1 / 13; }
    .ve-story-vine { display: none; }
    .ve-story-text { grid-column: 1 / 13; }
    .ve-talk-head, .ve-talk-head + .v-cta, .ve-talk-meta { grid-column: 1 / 13; }
  }
</style>
