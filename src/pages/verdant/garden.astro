---
import Verdant from "../../layouts/Verdant.astro";
import InkGrowth from "../../components/verdant/InkGrowth";
import Footer from "../../components/verdant/Footer";
import GardenLive from "../../components/verdant/GardenLive.astro";
import GrowingGarden from "../../components/verdant/GrowingGarden";
import { garden } from "../../data/verdant";
---

<Verdant title="Garden — personal finance, kept private — Verdant" image="/og/og-garden.jpg">
  <!-- ── HERO ── -->
  <GrowingGarden client:load className="v-field-bg" />

  <section class="vg-hero">
    <InkGrowth client:visible side="right" className="vg-hero-vine" />
    <div class="v-wrap vg-hero-inner">
      <p class="v-label">{garden.kind} · {garden.year} · {garden.status}</p>
      <h1 class="v-organic vg-hero-name">Garden</h1>
      <p class="vg-hero-line v-display">{garden.oneLine}</p>
      <p class="vg-hero-blurb">{garden.blurb}</p>
      <div class="vg-hero-actions">
        <a
          href="https://garden.khushinpatel1.workers.dev"
          class="v-cta v-cta--primary"
          target="_blank"
          rel="noopener"
          data-cursor="Open"
        >Start Garden →</a>
        <a href="#tour" class="v-cta" data-cursor="Down">Walk through it</a>
      </div>
      <p class="vg-hero-price">{garden.pricing}</p>
    </div>
    <div class="vg-hero-media">
      <GardenLive />
    </div>
  </section>

  <!-- ── THREE-BED TOUR ── -->
  <section id="tour" class="vg-tour">
    <div class="v-wrap">
      <div class="vg-tour-head" data-v-reveal>
        <p class="v-label">Three beds, one garden</p>
        <p class="vg-tour-intro v-display">Everything your money is doing — and nothing it shouldn't.</p>
      </div>
    </div>
    <div class="vg-screens">
      {garden.screens.map((s, i) => (
        <div class={`v-wrap vg-screen${i % 2 ? " vg-screen--alt" : ""}`} data-v-reveal>
          <div class="vg-screen-media">
            <div class="vg-phone"><div class="vg-phone-screen"><img src={s.img} alt={`Garden — ${s.tab}`} loading="lazy" width="780" height="1688" /></div></div>
          </div>
          <div class="vg-screen-text">
            <span class="v-label v-label--bare">0{i + 1} — {s.tab}</span>
            <h2 class="v-display vg-screen-line">{s.line}</h2>
            <p class="vg-screen-body">{s.body}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── GROVE — the presence, not a tab ── -->
  <section class="vg-grove">
    <div class="v-wrap vg-grove-inner" data-v-reveal>
      <div class="vg-grove-text">
        <span class="v-label v-label--bare">{garden.grove.tab} — reachable from anywhere</span>
        <h2 class="v-display vg-grove-line">{garden.grove.line}</h2>
        <p class="vg-grove-body">{garden.grove.body}</p>
        <p class="vg-grove-body" style="margin-top: 1.2rem; font-size: var(--text-sm); color: var(--leaf);">Example: {garden.groveExample}</p>
      </div>
      <div class="vg-grove-media">
        <div class="vg-phone"><div class="vg-phone-screen"><img src={garden.grove.img} alt="Garden — Grove" loading="lazy" width="780" height="1688" /></div></div>
      </div>
    </div>
  </section>

  <!-- ── WHAT STAYS YOURS — luminous light fields ── -->
  <section class="vg-features">
    <div class="vg-feat-bg" aria-hidden="true"></div>
    <div class="v-wrap">
      <p class="v-label" data-v-reveal>What stays yours</p>
      <ul class="vg-feat-list">
        <li class="vg-feat" data-v-reveal style="--d:0s">
          <span class="v-label v-label--bare">01</span>
          <p class="v-display vg-feat-text">{garden.notes[0]}</p>
        </li>
        <li class="vg-feat" data-v-reveal style="--d:0.06s">
          <span class="v-label v-label--bare">02</span>
          <p class="v-display vg-feat-text">{garden.accountConnection}</p>
        </li>
        <li class="vg-feat" data-v-reveal style="--d:0.12s">
          <span class="v-label v-label--bare">03</span>
          <p class="v-display vg-feat-text">{garden.notes[1]}</p>
        </li>
        <li class="vg-feat" data-v-reveal style="--d:0.18s">
          <span class="v-label v-label--bare">04</span>
          <p class="v-display vg-feat-text">{garden.notes[2]}</p>
        </li>
      </ul>
    </div>
  </section>

  <!-- ── PRIVACY — luminous light field ── -->
  <section class="vg-band">
    <div class="v-wrap vg-privacy">
      <p class="v-label" data-v-reveal>Plainly</p>
      <h2 class="v-display vg-privacy-head" data-v-reveal>
        Your numbers are locked<br />before they leave your hands.<br />The server holds the <span style="color: var(--leaf);">ciphertext</span>.<br />And can't read a cent of it.
      </h2>
    </div>
  </section>

  <!-- ── CLOSING ── -->
  <section class="vg-end">
    <div class="v-wrap vg-end-inner">
      <p class="v-display vg-end-line" data-v-reveal>The first thing grown here. Not the last.</p>
      <p class="v-label v-label--bare vg-end-price" data-v-reveal>{garden.pricing}</p>
      <form id="waitlist" class="vg-waitlist" method="POST" action="/api/waitlist" data-v-reveal>
        <label class="v-label v-label--bare vg-waitlist-label" for="vg-waitlist-email">Get in line</label>
        <div class="vg-waitlist-row">
          <input
            id="vg-waitlist-email"
            type="email"
            name="email"
            required
            placeholder="you@somewhere.calm"
            class="vg-waitlist-input"
            autocomplete="email"
          />
          <button type="submit" class="v-cta v-cta--primary" data-cursor="Send">Join the waitlist</button>
        </div>
      </form>
      <div class="vg-end-actions">
        <a href="/verdant" class="v-cta" data-cursor="Back">Back to the studio</a>
        <a href="/verdant/ethos#talk" class="v-cta" data-cursor="Write">Talk to us</a>
      </div>
    </div>
  </section>

  <Footer client:visible />
</Verdant>

<style is:global>
  /* PHONE FRAME — light finish */
  .vg-phone { --rad: 42px; --pad: 10px; position: relative; width: clamp(230px, 26vw, 300px);
    aspect-ratio: 400 / 812; border-radius: var(--rad); padding: var(--pad);
    background: linear-gradient(160deg, #f0f2ed 0%, #e8ebe6 46%, #dfe4d7 100%);
    box-shadow: 0 40px 90px -24px rgba(13,31,7,0.15), 0 0 0 1px rgba(47, 125, 79, 0.08),
                0 2px 0 rgba(255,255,255,0.6) inset, 0 -2px 8px rgba(0,0,0,0.06) inset; }
  .vg-phone--hero { width: clamp(250px, 30vw, 330px); }
  .vg-phone-screen { position: relative; width: 100%; height: 100%; overflow: hidden; border-radius: calc(var(--rad) - var(--pad)); background: var(--paper); }
  .vg-phone-screen img { width: 100%; height: 100%; object-fit: cover; object-position: 50% 0; }
  .vg-phone::after { content: ""; position: absolute; top: 14px; left: 50%; transform: translateX(-50%);
    width: 38%; height: 7px; border-radius: 5px; background: rgba(47, 125, 79, 0.2); z-index: 2; }

  /* HERO */
  .vg-hero { position: relative; min-height: 94svh; display: grid; grid-template-columns: 1.05fr 0.95fr;
    align-items: center; gap: 2rem; padding-top: 6rem; background: var(--paper); }
  .vg-hero-inner { position: relative; z-index: 2; }
  .vg-hero-name { font-size: var(--display-1); line-height: 0.9; color: var(--leaf); margin: 1.5rem 0 1rem; }
  .vg-hero-line { font-size: var(--display-2); color: var(--ink); max-width: 24ch; }
  .vg-hero-blurb { color: var(--ink-soft); font-size: var(--text-base); line-height: 1.6; max-width: 46ch; margin: 1.6rem 0 2rem; }
  .vg-hero-actions { display: flex; align-items: center; gap: 1.8rem; flex-wrap: wrap; }
  .vg-hero-price { margin-top: 1.4rem; color: var(--leaf); font-size: var(--text-base); letter-spacing: 0.01em; }
  .vg-hero-media { position: relative; z-index: 1; display: flex; justify-content: center; }
  .vg-hero-vine { position: absolute; right: 4%; top: 0; bottom: 0; width: 130px; z-index: 1; opacity: 0.8; }
  @media (max-width: 860px) { .vg-hero { grid-template-columns: 1fr; } .vg-hero-media { margin-top: 2rem; } .vg-hero-vine { display: none; } }

  /* TOUR */
  .vg-tour { padding-block: clamp(110px, 18vh, 260px); background: var(--paper); }
  .vg-tour-head { max-width: 38rem; margin-bottom: clamp(3rem, 8vh, 6rem); }
  .vg-tour-intro { font-size: var(--display-2); color: var(--ink); margin-top: 1rem; line-height: 1.1; }
  .vg-screens { display: flex; flex-direction: column; gap: clamp(4rem, 10vh, 9rem); }
  .vg-screen { display: grid; grid-template-columns: auto 1fr; gap: clamp(2.5rem, 6vw, 6rem); align-items: center; }
  .vg-screen--alt { grid-template-columns: 1fr auto; }
  .vg-screen--alt .vg-screen-media { order: 2; }
  .vg-screen-media { display: flex; justify-content: center; }
  .vg-screen-text { max-width: 38ch; }
  .vg-screen-line { font-size: var(--display-2); color: var(--leaf); margin: 0.7rem 0 1rem; line-height: 1.15; }
  .vg-screen-body { color: var(--ink-soft); line-height: 1.6; font-size: var(--text-base); }
  @media (max-width: 760px) { .vg-screen, .vg-screen--alt { grid-template-columns: 1fr; } .vg-screen--alt .vg-screen-media { order: 0; } }

  /* GROVE — luminous light inset ── */
  .vg-grove { padding: clamp(3rem, 8vh, 6rem) 0; background: var(--paper); }
  .vg-grove-inner { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: clamp(2rem, 5vw, 4rem);
    align-items: center; padding: clamp(2rem, 5vw, 3.5rem); border-radius: 4px;
    background: var(--paper-soft); }
  .vg-grove-line { font-size: var(--display-2); color: var(--leaf); margin: 0.8rem 0 1rem; line-height: 1.15; max-width: 18ch; }
  .vg-grove-body { color: var(--ink-soft); line-height: 1.6; font-size: var(--text-base); max-width: 44ch; }
  .vg-grove-media { display: flex; justify-content: center; }
  @media (max-width: 760px) { .vg-grove-inner { grid-template-columns: 1fr; } .vg-grove-media { margin-top: 1.5rem; } }

  /* FEATURES — luminous light field ── */
  .vg-features { position: relative; background: var(--paper-soft); padding-block: clamp(110px, 18vh, 260px); }
  .vg-features > .v-wrap { position: relative; z-index: 1; }
  .vg-feat-bg { position: absolute; top: 0; right: 0; bottom: 0; width: 40%;
    background: linear-gradient(100deg, transparent, var(--mist) 60%);
    pointer-events: none; }
  .vg-feat-list { list-style: none; padding: 0; margin: 2.5rem 0 0; max-width: 56rem; }
  .vg-feat { display: grid; grid-template-columns: auto 1fr; gap: 1.6rem; align-items: baseline;
    padding: 2rem 0; border-top: 1px solid var(--line); transition: padding-left .35s var(--ease); }
  .vg-feat:hover { padding-left: 1rem; }
  .vg-feat-text { font-size: var(--display-2); color: var(--leaf); line-height: 1.3; }
  .vg-feat:nth-child(even) { padding-left: clamp(0px, 4vw, 70px); }

  /* PRIVACY BAND — luminous light ── */
  .vg-band { background: var(--paper); padding-block: clamp(120px, 20vh, 220px); }
  .vg-privacy { max-width: 64ch; }
  .vg-privacy-head { font-size: var(--display-1); color: var(--ink); line-height: 1.2; margin-top: 1.5rem; }

  /* CLOSING */
  .vg-end { background: var(--paper); padding-block: clamp(110px, 18vh, 260px); }
  .vg-end-inner { display: flex; flex-direction: column; align-items: flex-start; gap: 1.6rem; }
  .vg-end-line { font-size: var(--display-2); color: var(--leaf); max-width: 20ch; }
  .vg-end-price { color: var(--leaf); }
  /* WAITLIST — left-aligned, grown into the closing column, not a centered SaaS box */
  .vg-waitlist { display: flex; flex-direction: column; gap: 0.9rem; width: 100%; max-width: 42rem; }
  .vg-waitlist-label { color: var(--ink-soft); }
  .vg-waitlist-row { display: flex; align-items: stretch; gap: 1.2rem; flex-wrap: wrap; }
  .vg-waitlist-input { flex: 1 1 18rem; min-width: 0; background: transparent; color: var(--ink);
    border: 0; border-bottom: 1px solid var(--line); padding: 0.7rem 0.2rem; font-size: var(--text-base);
    font-family: inherit; transition: border-color .35s var(--ease); }
  .vg-waitlist-input::placeholder { color: var(--ink-soft); opacity: 0.6; }
  .vg-waitlist-input:focus { outline: none; border-bottom-color: var(--leaf); }
  .vg-end-actions { display: flex; gap: 1.8rem; flex-wrap: wrap; }
</style>
