---
import Verdant from "../../layouts/Verdant.astro";
import Footer from "../../components/verdant/Footer";
import GardenLive from "../../components/verdant/GardenLive.astro";
import FeatureRow from "../../components/verdant/kit/FeatureRow.astro";
import CTAClose1 from "../../components/verdant/kit/CTAClose1.astro";
import GardenTour from "../../components/verdant/GardenTour";
import { garden, privacySpectrum } from "../../data/verdant";
---

<Verdant title="Garden — Personal finance, kept private" description={garden.blurb}>
  <section class="v-garden-hero">
    <div class="v-garden-hero__stack">
      <h1 class="v-garden-hero__headline">{garden.name}</h1>
      <p class="v-garden-hero__sub">{garden.oneLine}</p>
      <div class="v-garden-hero__ctas">
        <a href={garden.url} class="v-cta v-cta--primary">Try Garden</a>
        <a href="/verdant/security" class="v-cta">Security</a>
      </div>
    </div>
    <div class="v-garden-hero__media v-product-shot">
      <GardenLive />
    </div>
  </section>

  <FeatureRow
    align="left"
    headline="See the whole garden"
    body="Net worth across every account. One number, one place. The first thing you see when you open the app."
    media={true}
    mediaSrc={garden.screens[0].img}
    product={true}
  />

  <FeatureRow
    align="right"
    headline="Pull the weeds"
    body="Where it goes, what it adds up to, and the quiet subscriptions draining you. Budgets that track themselves."
    media={true}
    mediaSrc={garden.screens[1].img}
    product={true}
  />

  <FeatureRow
    align="left"
    headline="Plant and untangle"
    body="Goals with real dates. Debt in order. One number to pay. A year you'll be free. The interest you'll save."
    media={true}
    mediaSrc={garden.screens[2].img}
    product={true}
  />

  <div style="padding: clamp(3rem, 8vw, 5rem) clamp(20px, 5vw, 56px); max-width: var(--maxw); margin: 0 auto;">
    <GardenTour client:visible />
  </div>

  <!-- "Built on" — de-slopped from three equal cards into proof mapped to the
       real privacy tiers (src/data/verdant.ts privacySpectrum), per audit §4. -->
  <div class="v-built-on">
    <h2 class="v-built-on__title">Built on the privacy spectrum</h2>
    <div class="v-built-on__rows">
      {privacySpectrum.map((tier) => (
        <div class="v-built-on__row">
          <span class="v-built-on__n">{tier.n}</span>
          <div class="v-built-on__copy">
            <span class="v-built-on__label">{tier.label}</span>
            <p class="v-built-on__reality">{tier.reality}</p>
          </div>
          <span class="v-built-on__status">{tier.status}</span>
        </div>
      ))}
    </div>
  </div>

  <CTAClose1
    headline="Start your garden"
    sub="Private. Encrypted. On your device."
    cta={{ label: "Try Garden", href: garden.url }}
    ctaSecondary={{ label: "Pricing", href: "/verdant/pricing" }}
  />

  <Footer client:visible />
</Verdant>

<style>
  .v-garden-hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 8vw, 4rem);
    align-items: center;
    padding: clamp(5.5rem, 18vw, 8rem) clamp(20px, 5vw, 56px) clamp(3rem, 10vw, 6rem);
    max-width: var(--maxw);
    margin: 0 auto;
  }
  @media (min-width: 920px) {
    .v-garden-hero {
      grid-template-columns: 1.05fr 0.95fr;
      padding-top: clamp(3rem, 10vw, 6rem);
    }
  }
  .v-garden-hero__stack { display: flex; flex-direction: column; gap: 1.5rem; }
  .v-garden-hero__headline { font-size: var(--display-1); color: var(--fg); line-height: 1.02; font-family: var(--font-display); }
  .v-garden-hero__sub { font-size: var(--text-lg); color: var(--muted); line-height: 1.5; max-width: 32em; }
  .v-garden-hero__ctas { display: flex; flex-wrap: wrap; gap: 1.75rem; margin-top: 0.5rem; align-items: center; }
  .v-garden-hero__media { display: flex; align-items: center; justify-content: center; }

  .v-built-on {
    padding: clamp(3rem, 8vw, 5rem) clamp(20px, 5vw, 56px);
    max-width: var(--maxw);
    margin: 0 auto;
  }
  .v-built-on__title { font-size: var(--text-3xl); color: var(--fg); line-height: 1.1; margin-bottom: clamp(1.5rem, 4vw, 2.5rem); }
  .v-built-on__rows { display: flex; flex-direction: column; }
  .v-built-on__row {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    gap: 1.5rem;
    align-items: baseline;
    padding: 1.4rem 0;
    border-top: 1px solid var(--line);
  }
  .v-built-on__n { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--gold-ink); }
  .v-built-on__copy { display: flex; flex-direction: column; gap: 0.4rem; }
  .v-built-on__label { font-family: var(--font-display); font-size: var(--text-xl); color: var(--fg); }
  .v-built-on__reality { font-size: var(--text-sm); color: var(--muted); line-height: 1.6; max-width: 36em; }
  .v-built-on__status {
    font-family: var(--font-mono); font-size: var(--text-2xs); letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--muted); white-space: nowrap;
  }
</style>
