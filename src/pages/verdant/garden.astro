---
import Verdant from "../../layouts/Verdant.astro";
import Footer from "../../components/verdant/Footer";
import Hero from "../../components/verdant/kit/Hero.astro";
import FeatureRow from "../../components/verdant/kit/FeatureRow.astro";
import CardGrid from "../../components/verdant/kit/CardGrid.astro";
import Card from "../../components/verdant/kit/Card.astro";
import CTABand from "../../components/verdant/kit/CTABand.astro";
import GardenTour from "../../components/verdant/GardenTour";
import { garden } from "../../data/verdant";

// Privacy spectrum — the honest 3-tier model (plan §0 truth correction).
// NEVER "never leaves your device" — each tier names exactly what touches a server.
const spectrum = [
  { n: "01", tier: "Manual", note: "Type it in yourself. Fully local — nothing to sync, nothing to send." },
  { n: "02", tier: "AI import", note: "A statement or CSV, read once by the parser to pull out the numbers. Encrypted before it's stored." },
  { n: "03", tier: "Bank link", note: "When sync arrives: your bank's data travels in labeled, encrypted transit — never sold, never read by us at rest." },
];
---

<Verdant title="Garden — Personal finance, kept private" description={garden.blurb}>
  <Hero
    headline={garden.name}
    sub={garden.oneLine}
    cta1={{ label: "Try Garden", href: garden.url }}
    cta2={{ label: "Security", href: "/verdant/security" }}
    media={true}
    videoSrc="/verdant/media/hero-landscape-2.webp"
    mediaPoster={garden.cover}
  />

  <FeatureRow
    align="left"
    headline="See the whole garden"
    body="Net worth across every account. One number, one place. The first thing you see when you open the app."
    media={true}
    mediaSrc={garden.screens[0].img}
  />

  <FeatureRow
    align="right"
    headline="Pull the weeds"
    body="Where it goes, what it adds up to, and the quiet subscriptions draining you. Budgets that track themselves."
    media={true}
    mediaSrc={garden.screens[1].img}
  />

  <FeatureRow
    align="left"
    headline="Plant and untangle"
    body="Goals with real dates. Debt in order. One number to pay. A year you'll be free. The interest you'll save."
    media={true}
    mediaSrc={garden.screens[2].img}
  />

  <div style="padding: clamp(3rem, 8vw, 5rem) clamp(20px, 5vw, 56px); max-width: var(--maxw); margin: 0 auto;">
    <GardenTour client:visible />
  </div>

  <CardGrid cols={3} title="Built on">
    <Card headline="Private by structure" blurb="You choose the tier; the architecture holds it." />
    <Card headline="Works offline" blurb="Your garden is yours whether or not there's a signal." />
    <Card headline="Honest model" blurb="You pay for the app. That's the whole business." />
  </CardGrid>

  <CTABand
    headline="Start your garden"
    sub="Private. Encrypted. On your device."
    cta={{ label: "Try Garden", href: garden.url }}
    ctaSecondary={{ label: "Pricing", href: "/verdant/pricing" }}
  />

  <Footer client:visible />
</Verdant>
