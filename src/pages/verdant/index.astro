---
import Verdant from "../../layouts/Verdant.astro";
import Footer from "../../components/verdant/Footer";
import Hero from "../../components/verdant/kit/Hero.astro";
import FeatureRow from "../../components/verdant/kit/FeatureRow.astro";
import CTABand from "../../components/verdant/kit/CTABand.astro";
import { brand, garden } from "../../data/verdant";
---

<Verdant title="Verdant — software grown for people">
  <Hero
    eyebrow="Verdant Studio — independent software"
    headline="Private personal finance."
    sub="Track accounts, budgets, goals, and net worth — without selling your data to do it."
    cta1={{ label: "Join the beta", href: "/verdant/beta" }}
    cta2={{ label: "See Garden", href: "/verdant/garden" }}
    media={true}
    mediaSrc="/verdant/garden/garden-home.webp"
    product={true}
  />

  <FeatureRow
    align="left"
    headline="Security and trust are structural"
    body="Manual entry stays fully local. AI import touches your data once. Bank sync travels labeled plaintext. You choose the tier that fits your work."
    media={false}
    cta={{ label: "Read the privacy spectrum", href: "/verdant/security" }}
  />

  <CTABand
    headline="Ready to take control"
    sub="Start with the Garden beta. Early access, no ads, no surprises."
    cta={{ label: "Join the beta", href: "/verdant/beta" }}
    ctaSecondary={{ label: "See what's next", href: "/verdant/roadmap" }}
  />

  <FeatureRow
    align="left"
    headline="Why we built this"
    body="Privacy by structure, not by claim. We can't sell what we never touch. Software should answer to you, not the people who bought ads. Build one thing well, not ten things anxiously."
    media={true}
    mediaSrc="/verdant/art/ethos-sand.jpg"
  />

  <Footer client:visible />
</Verdant>
