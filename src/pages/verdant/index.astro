---
import Verdant from "../../layouts/Verdant.astro";
import HeroGarden from "../../components/verdant/HeroGarden";
import VineBorder from "../../components/verdant/VineBorder";
import Footer from "../../components/verdant/Footer";
import { garden, ethos } from "../../data/verdant";
---

<Verdant title="Verdant - software grown for people">
  <!-- HERO: luminous, type-on-light. Botanical garden field as signature moment. -->
  <section class="vh-hero">
    <HeroGarden client:load className="vh-hero-garden" style={{ opacity: 0.12 }} />
    <div class="v-wrap vh-hero-inner">
      <p class="v-label">Verdant Studio - independent software</p>
      <h1 class="v-display vh-hero-head" data-v-reveal>
        <span>Software grown for</span> <span style="color: var(--leaf);">people</span><span>, not advertisers.</span>
      </h1>
      <p class="vh-hero-sub" data-v-reveal>
        Quiet software - tools that do their work and get out of the way.
        Nothing here watches you back.
      </p>
      <div class="vh-hero-actions" data-v-reveal>
        <a href="#work" class="v-cta">See the work</a>
        <a href="/verdant/ethos" class="v-cta">The ethos</a>
      </div>
    </div>
  </section>

  <!-- MANIFESTO: tight, dense, on mist wash — asymmetric column -->
  <section class="vh-manifesto-section">
    <VineBorder position="top" />
    <div class="v-wrap vh-manifesto">
      <div style="max-width: 32ch;">
        <p class="v-label">The manifesto</p>
        <h2 class="v-display vh-manifesto-head" data-v-reveal>
          Care spent on what <span style="color: var(--leaf);">stays quiet</span>.
        </h2>
      </div>
      <div class="vh-manifesto-body">
        <ul class="vh-creed">
          {ethos.creed.map((line, i) => (
            <li class="vh-creed-item" data-v-reveal style={`--d:${i * 0.04}s`}>{line}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- WORK / THE FIRST PROJECT: asymmetric, visual weight on Garden -->
  <section id="work" class="vh-work">
    <div class="v-wrap vh-work-wrapper">
      <div class="vh-work-head" data-v-reveal>
        <p class="v-label">The first project</p>
      </div>

      <a href="/verdant/garden" class="vh-garden" data-v-reveal>
        <div class="vh-garden-media">
          <div class="vh-phone"><div class="vh-phone-screen"><img src={garden.cover} alt="Garden - overview" loading="lazy" /></div></div>
          <div class="vh-phone vh-phone--back"><div class="vh-phone-screen"><img src={garden.vaultScreen} alt="Garden - encrypted vault" loading="lazy" /></div></div>
        </div>
        <div class="vh-garden-text">
          <div class="vh-product-meta">
            <span class="v-label v-label--bare">{garden.idx} - {garden.kind}</span>
            <span class="vh-product-year">{garden.year} - {garden.status}</span>
          </div>
          <h2 class="v-display vh-garden-name" style="font-size: var(--display-1);">Garden</h2>
          <p class="vh-product-line">{garden.oneLine}</p>
          <p class="vh-product-blurb">{garden.blurb}</p>
          <span class="v-cta">Walk through Garden</span>
        </div>
      </a>
    </div>

    <div class="v-wrap vh-work-note">
      <p class="vh-more-note" data-v-reveal>
        A second project is in the soil - it ships when it's ready, not before.
      </p>
    </div>
  </section>

  <!-- PULL QUOTE: big Instrument Serif on paper -->
  <section class="vh-quote">
    <div class="v-wrap">
      <p class="v-organic vh-quote-mark">"</p>
      <p class="v-display vh-quote-text" data-v-reveal>
        The best software is like a good garden. You feel it was tended, but you
        never catch it <em>trying</em>.
      </p>
      <p class="v-label vh-quote-by">Khushin Patel - Verdant</p>
    </div>
  </section>

  <!-- CLOSING CTA: soft mist to dawn luminous gradient, NO koson moon print -->
  <section class="vh-cta-band">
    <div class="v-wrap vh-cta-inner">
      <h2 class="v-display vh-cta-title" data-v-reveal>
        Grow something <span style="color: var(--leaf);">quiet</span>.
      </h2>
      <a href="/verdant/ethos#talk" class="v-cta">Start a conversation</a>
    </div>
  </section>

  <Footer client:visible />
</Verdant>

<style is:global>
  /* HERO - luminous, type-on-light. GrowingGarden soft light field behind. */
  .vh-hero { position: relative; min-height: 100svh; display: flex; flex-direction: column; justify-content: center; overflow: hidden; background: var(--paper); }
  .vh-hero-garden { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .vh-hero-inner { position: relative; z-index: 1; padding-top: 8rem; padding-bottom: 4rem; }
  .vh-hero-head { font-size: var(--display-1); color: var(--ink); max-width: 15ch; margin-top: 2.4rem; line-height: 1.1; }
  .vh-hero-sub { font-family: var(--font-display); font-size: var(--text-lg); line-height: 1.6; color: var(--ink); max-width: 44ch; margin-top: 2rem; }
  .vh-hero-actions { display: flex; gap: 1.6rem; flex-wrap: wrap; margin-top: 2.4rem; }

  /* MANIFESTO - on paper-soft wash */
  .vh-manifesto-section { background: var(--paper-soft); padding: clamp(80px, 14vh, 200px) 0; }
  .vh-manifesto { position: relative; }
  .vh-manifesto-label-block { margin-bottom: 2rem; }
  .vh-manifesto-head { font-size: var(--display-2); color: var(--ink); max-width: 18ch; margin-bottom: 3.5rem; line-height: 1.1; }
  .vh-manifesto-body { max-width: 62ch; }
  .vh-creed { list-style: none; padding: 0; margin: 0; }
  .vh-creed-item { font-family: var(--font-display); font-size: var(--text-lg); line-height: 1.45; color: var(--ink-soft);
    padding: 1.4rem 0; border-top: 1px solid var(--line); transition: padding-left .35s var(--ease), color .35s; }
  .vh-creed-item:hover { padding-left: 0.8rem; color: var(--ink); }

  /* WORK - the first project on light, asymmetric layout */
  .vh-work { background: var(--paper); padding: clamp(100px, 16vh, 240px) 0; }
  .vh-work-head { margin-bottom: 3rem; }
  .vh-work-wrapper { position: relative; }
  .vh-garden { display: grid; grid-template-columns: 1fr auto; gap: clamp(3rem, 8vw, 8rem); align-items: center; color: inherit; text-decoration: none; }
  .vh-garden-media { position: relative; display: flex; justify-content: center; min-width: 0; order: 2; }
  .vh-garden-text { max-width: 48ch; position: relative; z-index: 1; order: 1; }
  .vh-product-meta { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: baseline; gap: 0.6rem 1rem; }
  .vh-product-year { font-family: var(--font-mono); font-size: var(--text-2xs); letter-spacing: 0.14em; color: var(--ink-soft); }
  .vh-garden-name { color: var(--leaf); margin: 1rem 0 1rem; transition: color .3s; line-height: 1.1; }
  .vh-garden:hover .vh-garden-name { color: var(--leaf-deep); }
  .vh-product-line { font-family: var(--font-display); font-size: var(--text-xl); color: var(--ink); margin-bottom: 1.2rem; line-height: 1.4; }
  .vh-product-blurb { color: var(--ink-soft); line-height: 1.75; max-width: 48ch; margin-bottom: 1.8rem; font-size: var(--text-lg); }
  .vh-work-note { padding-top: clamp(3rem, 6vh, 5rem); }
  .vh-more-note { font-family: var(--font-mono); font-size: var(--text-2xs); letter-spacing: 0.06em; color: var(--ink-soft);
    padding-top: 1.6rem; border-top: 1px solid var(--line); max-width: 48ch; }

  /* phone frame (home) */
  .vh-phone { --rad: 40px; --pad: 9px; position: relative; width: clamp(190px, 21vw, 250px); aspect-ratio: 400 / 812;
    border-radius: var(--rad); padding: var(--pad); flex: none;
    background: linear-gradient(160deg, #2a3b27 0%, #16271a 46%, #0a1610 100%);
    box-shadow: 0 40px 90px -34px rgba(13,26,16,0.6), 0 0 0 1.5px rgba(255,255,255,0.05),
                0 2px 0 rgba(255,255,255,0.08) inset, 0 -2px 8px rgba(0,0,0,0.4) inset;
    transition: transform .6s var(--ease); }
  .vh-phone-screen { width: 100%; height: 100%; overflow: hidden; border-radius: calc(var(--rad) - var(--pad)); background: var(--paper); }
  .vh-phone-screen img { width: 100%; height: 100%; object-fit: cover; object-position: 50% 0; }
  .vh-phone--back { position: absolute; left: 22%; top: 8%; z-index: -1; transform: rotate(6deg) scale(0.92); opacity: 0.92; }
  .vh-garden:hover .vh-phone { transform: translateY(-8px); }
  .vh-garden:hover .vh-phone--back { transform: rotate(9deg) scale(0.92) translateY(-4px); }
  @media (max-width: 800px) { .vh-garden { grid-template-columns: 1fr; } .vh-phone--back { display: none; } }

  /* QUOTE */
  .vh-quote { background: var(--paper); padding: clamp(80px, 14vh, 200px) 0; text-align: center; }
  .vh-quote .v-wrap { max-width: 56rem; }
  .vh-quote-mark { font-size: var(--text-4xl); line-height: 0.4; color: var(--sage); }
  .vh-quote-text { font-size: var(--display-2); line-height: 1.35; color: var(--ink); margin: 0 auto 1.6rem; }
  .vh-quote-by { justify-content: center; }

  /* CTA BAND - soft mist to dawn gradient, NO koson print */
  section.vh-cta-band { background: linear-gradient(135deg, var(--mist), var(--dawn)); padding: clamp(120px, 18vh, 200px) 0; text-align: center; }
  .vh-cta-inner { display: flex; flex-direction: column; align-items: center; gap: 2rem; position: relative; z-index: 1; }
  .vh-cta-title { font-size: var(--display-1); color: var(--ink); line-height: 1.1; }
  @media (max-width: 800px) {
    section.vh-cta-band { padding: clamp(80px, 12vh, 150px) 0; }
  }
</style>
