---
import Verdant from "../../layouts/Verdant.astro";
import HeroGarden from "../../components/verdant/HeroGarden";
import VineBorder from "../../components/verdant/VineBorder";
import Footer from "../../components/verdant/Footer";
import { garden, ethos } from "../../data/verdant";
---

<Verdant title="Verdant — Independent Software Studio">
  <!-- HERO: asymmetric split. Text pinned left, the garden grows on the right. -->
  <section class="vh-hero vh-sec">
    <HeroGarden client:load className="vh-hero-garden" />
    <div class="vh-hero-text">
      <p class="v-label">Verdant Studio - independent software</p>
      <h1 class="v-display vh-hero-head">
        Software that answers<br />to <span style="color: var(--leaf);">you</span>,<br />and no one else.
      </h1>
      <p class="vh-hero-sub">
        Most money apps sell your spending to stay free. We sell the app instead — you own the software, the numbers stay yours.
      </p>
      <p class="vh-hero-sub">
        We make a living the old-fashioned way: you pay us. No ads, no data sold, no third party reading over your shoulder. That one fact decides everything we build.
      </p>
      <div class="vh-hero-actions">
        <a href="#work" class="v-cta">See Garden</a>
        <a href="/verdant/ethos" class="v-cta">What we believe</a>
      </div>
    </div>
    <div class="vh-hero-media">
      <div class="vh-phone"><div class="vh-phone-screen"><img src={garden.cover} alt="Garden — personal finance" loading="eager" width="780" height="1688" /></div></div>
      <div class="vh-phone vh-phone--back"><div class="vh-phone-screen"><img src={garden.vaultScreen} alt="Garden — encrypted vault" loading="eager" width="780" height="1688" /></div></div>
    </div>
    <span class="vh-num vh-num--hero" aria-hidden="true">00</span>
  </section>

  <!-- MANIFESTO: axis flips right. Tight, dense, on mist wash. -->
  <section class="vh-manifesto vh-sec" data-v-choreograph>
    <VineBorder position="top" />
    <span class="vh-num" aria-hidden="true">01</span>
    <div class="vh-manifesto-lede" data-v-choreo-scale>
      <p class="v-label">The manifesto</p>
      <h2 class="v-display vh-manifesto-head">
        Care spent on what <span style="color: var(--leaf);">stays quiet</span>.
      </h2>
    </div>
    <ul class="vh-creed">
      {ethos.creed.map((line, i) => (
        <li class="vh-creed-item" data-v-choreo-slide style={`--d:${i * 0.04}s`}>{line}</li>
      ))}
    </ul>
  </section>

  <!-- WORK: the first project. Full weight, text left / phones right. -->
  <section id="work" class="vh-work vh-sec">
    <span class="vh-num" aria-hidden="true">02</span>
    <a href="/verdant/garden" class="vh-garden">
      <div class="vh-garden-text">
        <div class="vh-product-meta">
          <span class="v-label v-label--bare">{garden.idx} - {garden.kind}</span>
          <span class="vh-product-year">{garden.year} - {garden.status}</span>
        </div>
        <h2 class="v-display vh-garden-name">Garden</h2>
        <p class="vh-product-line">{garden.oneLine}</p>
        <p class="vh-product-blurb">{garden.blurb}</p>
        <p class="vh-product-blurb" style="font-size: var(--text-sm); color: var(--leaf); margin-top: 1.2rem;">{garden.onboarding}</p>
        <span class="v-cta">Walk through Garden</span>
      </div>
      <div class="vh-garden-media">
        <div class="vh-phone"><div class="vh-phone-screen"><img src={garden.cover} alt="Garden - overview" loading="lazy" width="780" height="1688" /></div></div>
        <div class="vh-phone vh-phone--back"><div class="vh-phone-screen"><img src={garden.vaultScreen} alt="Garden - encrypted vault" loading="lazy" width="780" height="1688" /></div></div>
      </div>
    </a>
    <p class="vh-more-note" data-v-reveal>
      A second project is in the soil - it ships when it's ready, not before.
    </p>
  </section>

  <!-- QUOTE: left-pinned, mark hangs into the margin. Not centered. -->
  <section class="vh-quote vh-sec">
    <span class="vh-num" aria-hidden="true">03</span>
    <p class="v-organic vh-quote-mark" aria-hidden="true">"</p>
    <p class="v-display vh-quote-text" data-v-reveal>
      The best software is like a good garden. You feel it was tended, but you
      never catch it <em>trying</em>.
    </p>
    <p class="v-label vh-quote-by">Khushin Patel - Verdant</p>
  </section>

  <!-- CTA: left-pinned, on a soft dawn wash. Not a centered stack. -->
  <section class="vh-cta-band vh-sec" data-v-choreograph>
    <span class="vh-num" aria-hidden="true">04</span>
    <h2 class="v-display vh-cta-title" data-v-choreo-slide>
      Software that's on <span style="color: var(--leaf);">your</span> side, for once.
    </h2>
    <a href="https://garden.khushinpatel1.workers.dev" class="v-cta vh-cta-link" target="_blank" rel="noopener" data-v-choreo-slide data-v-choreodelay="0.16">Start Garden</a>
    <p class="v-label" style="margin-top: 1.6rem; color: var(--leaf);" data-v-choreo-slide data-v-choreodelay="0.24">{garden.pricing}</p>
  </section>

  <Footer client:visible />
</Verdant>

<style is:global>
  /* Off-axis editorial grid. Every section is a 12-col field; content is
     pinned to a column range, not floated in a centered .v-wrap. The axis
     flips down the page (left / right / left) so no two sections share it. */
  .vh-sec {
    position: relative;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    column-gap: clamp(12px, 1.6vw, 28px);
    padding-inline: clamp(20px, 5vw, 72px);
  }

  /* Section numerals — mono, hung in the gutter. Editorial rhythm marker. */
  .vh-num {
    position: absolute; top: clamp(2rem, 5vh, 4rem); left: clamp(20px, 5vw, 72px);
    font-family: var(--font-mono); font-size: var(--text-2xs);
    letter-spacing: 0.2em; color: var(--moss); opacity: 0.7;
  }
  .vh-num::after { content: ""; display: inline-block; width: 2.2rem; height: 1px;
    background: var(--sage); vertical-align: middle; margin-left: 0.7rem; }

  /* HERO — asymmetric split: text in the left 7 cols, phone mockups on the right. */
  .vh-hero { min-height: 100svh; align-content: center; overflow: hidden; background: var(--paper); align-items: center; }
  .vh-hero-garden {
    position: absolute; top: 0; right: 0; bottom: 0; left: 38%;
    z-index: 0; pointer-events: none; opacity: 0.55;
    -webkit-mask-image: linear-gradient(100deg, transparent, #000 38%);
            mask-image: linear-gradient(100deg, transparent, #000 38%);
  }
  .vh-hero-text { grid-column: 1 / 7; position: relative; z-index: 1; padding-block: 6rem 2rem; }
  .vh-hero-media { grid-column: 8 / 13; position: relative; z-index: 1; display: flex; justify-content: center; align-items: center; padding-block: 4rem; }
  .vh-hero-head { font-size: var(--display-1); color: var(--ink); margin-top: 2.4rem; line-height: 1.05; }
  .vh-hero-sub { font-family: var(--font-display); font-size: var(--text-xl); line-height: 1.55; color: var(--ink); max-width: 38ch; margin-top: 2rem; }
  .vh-hero-actions { display: flex; gap: 1.6rem; flex-wrap: wrap; margin-top: 2.6rem; }
  .vh-num--hero { top: auto; bottom: clamp(2rem, 6vh, 4rem); }
  @media (max-width: 860px) { .vh-hero-text { grid-column: 1 / 13; } .vh-hero-media { display: none; } }

  /* MANIFESTO — axis flips RIGHT. Lede pinned right, creed below it. */
  .vh-manifesto { background: var(--paper-soft); padding-block: clamp(90px, 16vh, 220px); row-gap: 3.5rem; }
  .vh-manifesto-lede { grid-column: 6 / 13; }
  .vh-manifesto-head { font-size: var(--display-2); color: var(--ink); max-width: 16ch; margin-top: 1.2rem; line-height: 1.1; }
  .vh-creed { grid-column: 6 / 12; list-style: none; padding: 0; margin: 0; }
  .vh-creed-item { font-family: var(--font-display); font-size: var(--text-lg); line-height: 1.45; color: var(--ink-soft);
    padding: 1.4rem 0; border-top: 1px solid var(--line); transition: padding-left .35s var(--ease), color .35s; }
  .vh-creed-item:hover { padding-left: 0.8rem; color: var(--ink); }

  /* WORK — text left (cols 1-6), phones right (cols 7-13), real weight. */
  .vh-work { background: var(--paper); padding-block: clamp(110px, 18vh, 260px); align-items: center; row-gap: 4rem; }
  .vh-garden { grid-column: 1 / 13; display: grid; grid-template-columns: minmax(0, 1fr) auto;
    gap: clamp(3rem, 8vw, 9rem); align-items: center; color: inherit; text-decoration: none; }
  .vh-garden-text { max-width: 46ch; }
  .vh-product-meta { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: baseline; gap: 0.6rem 1rem; }
  .vh-product-year { font-family: var(--font-mono); font-size: var(--text-2xs); letter-spacing: 0.14em; color: var(--ink-soft); }
  .vh-garden-name { color: var(--leaf); font-size: var(--display-1); margin: 1rem 0; transition: color .3s; line-height: 1.05; }
  .vh-garden:hover .vh-garden-name { color: var(--leaf-deep); }
  .vh-product-line { font-family: var(--font-display); font-size: var(--text-xl); color: var(--ink); margin-bottom: 1.2rem; line-height: 1.4; }
  .vh-product-blurb { color: var(--ink-soft); line-height: 1.75; max-width: 46ch; margin-bottom: 1.8rem; font-size: var(--text-lg); }
  .vh-more-note { grid-column: 1 / 7; font-family: var(--font-mono); font-size: var(--text-2xs); letter-spacing: 0.06em;
    color: var(--ink-soft); padding-top: 1.6rem; border-top: 1px solid var(--line); }
  .vh-garden-media { position: relative; display: flex; justify-content: center; min-width: 0; }

  /* phone frame */
  .vh-phone { --rad: 40px; --pad: 9px; position: relative; width: clamp(200px, 22vw, 270px); aspect-ratio: 400 / 812;
    border-radius: var(--rad); padding: var(--pad); flex: none;
    background: linear-gradient(160deg, #2a3b27 0%, #16271a 46%, #0a1610 100%);
    box-shadow: 0 40px 90px -34px rgba(13,26,16,0.6), 0 0 0 1.5px rgba(255,255,255,0.05),
                0 2px 0 rgba(255,255,255,0.08) inset, 0 -2px 8px rgba(0,0,0,0.4) inset;
    transition: transform .6s var(--ease); }
  .vh-phone-screen { width: 100%; height: 100%; overflow: hidden; border-radius: calc(var(--rad) - var(--pad)); background: var(--paper); }
  .vh-phone-screen img { width: 100%; height: 100%; object-fit: cover; object-position: 50% 0; }
  .vh-phone--back { position: absolute; left: 22%; top: 8%; z-index: -1; transform: rotate(6deg) scale(0.92); opacity: 0.92; }
  .vh-garden:hover .vh-phone { transform: translateY(-8px); }
  .vh-garden:hover .vh-phone--back { transform: rotate(9deg) scale(0.92) translateY(-4px); }

  /* QUOTE — left-pinned, mark hangs into the left gutter. Not centered. */
  .vh-quote { background: var(--paper); padding-block: clamp(90px, 16vh, 220px); }
  .vh-quote-mark { grid-column: 1 / 2; grid-row: 1; align-self: start; justify-self: start;
    font-size: var(--text-4xl); line-height: 0.4; color: var(--sage); margin-left: -0.4rem; }
  .vh-quote-text { grid-column: 2 / 10; font-size: var(--display-2); line-height: 1.32; color: var(--ink); margin-bottom: 1.6rem; }
  .vh-quote-by { grid-column: 2 / 10; }

  /* CTA — left-pinned on a dawn wash. Not a centered stack. */
  section.vh-cta-band { background: linear-gradient(135deg, var(--mist), var(--dawn)); padding-block: clamp(120px, 20vh, 220px); align-content: center; }
  .vh-cta-title { grid-column: 1 / 9; font-size: var(--display-1); color: var(--ink); line-height: 1.05; }
  .vh-cta-link { grid-column: 1 / 9; margin-top: 2rem; }

  /* Responsive — collapse to a single column, drop the off-axis offsets. */
  @media (max-width: 860px) {
    .vh-hero-garden { left: 0; opacity: 0.4; -webkit-mask-image: none; mask-image: none; }
    .vh-hero-text { grid-column: 1 / 13; }
    .vh-manifesto-lede, .vh-creed { grid-column: 1 / 13; }
    .vh-garden { grid-template-columns: 1fr; }
    .vh-phone--back { display: none; }
    .vh-more-note { grid-column: 1 / 13; }
    .vh-quote-text, .vh-quote-by { grid-column: 1 / 13; }
    .vh-quote-mark { grid-column: 1 / 13; }
    .vh-cta-title, .vh-cta-link { grid-column: 1 / 13; }
  }
</style>
