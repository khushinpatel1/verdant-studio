---
import Verdant from "../../layouts/Verdant.astro";
import Footer from "../../components/verdant/Footer";
import GardenLive from "../../components/verdant/GardenLive.astro";
import FeatureRow from "../../components/verdant/kit/FeatureRow.astro";
import CTAClose1 from "../../components/verdant/kit/CTAClose1.astro";
import { garden } from "../../data/verdant";
---

<Verdant title="Verdant, software grown for people">
  <section class="v-home-hero" data-v-choreograph>
    <div class="v-home-hero__stack">
      <div class="v-home-hero__eyebrow" data-v-choreo-slide data-v-choreo-delay="0">Verdant Studio. Independent software.</div>
      <h1 class="v-home-hero__headline" data-v-choreo-slide data-v-choreo-delay="0.08">Private personal finance.</h1>
      <p class="v-home-hero__sub" data-v-choreo-hold data-v-choreo-delay="0.2">Track accounts, budgets, goals, and net worth without selling your data to do it.</p>
      <div class="v-home-hero__ctas" data-v-choreo-hold data-v-choreo-delay="0.2">
        <a href={garden.url} class="v-cta v-cta--primary">Try Garden</a>
        <a href="/verdant/beta" class="v-cta">Join the beta</a>
      </div>
    </div>
    <div class="v-home-hero__media v-product-shot" data-v-choreo-scale data-v-choreo-delay="0.15">
      <GardenLive />
    </div>
  </section>

  <FeatureRow
    align="left"
    headline="Security and trust are structural"
    body="Manual entry stays fully local. AI import touches your data once. Bank sync travels labeled plaintext. You choose the tier that fits your work."
    media={false}
    cta={{ label: "Read the privacy spectrum", href: "/verdant/security" }}
  />

  <FeatureRow
    align="left"
    headline="Why we built this"
    body="Privacy by structure, not by claim. We can't sell what we never touch. Software should answer to you, not the people who bought ads. Build one thing well, not ten things anxiously."
    media={true}
    mediaSrc="/verdant/art/ethos-sand.jpg"
  />

  <CTAClose1
    headline="Ready to take control"
    sub="Start with the Garden beta. Early access, no ads, no surprises."
    cta={{ label: "Join the beta", href: "/verdant/beta" }}
    ctaSecondary={{ label: "See what's next", href: "/verdant/roadmap" }}
  />

  <Footer client:visible />
</Verdant>

<style>
  .v-home-hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 8vw, 4rem);
    align-items: center;
    padding: clamp(5.5rem, 18vw, 8rem) clamp(20px, 5vw, 56px) clamp(3rem, 10vw, 6rem);
    max-width: var(--maxw);
    margin: 0 auto;
  }
  @media (min-width: 920px) {
    .v-home-hero {
      grid-template-columns: 1.05fr 0.95fr;
      padding-top: clamp(3rem, 10vw, 6rem);
    }
  }
  .v-home-hero__stack { display: flex; flex-direction: column; gap: 1.5rem; }
  .v-home-hero__eyebrow {
    font-family: var(--font-mono); font-size: var(--text-xs);
    text-transform: uppercase; letter-spacing: 0.1em; color: var(--gold-ink);
  }
  .v-home-hero__headline { font-size: var(--display-1); color: var(--fg); line-height: 1.02; }
  .v-home-hero__sub { font-size: var(--text-lg); color: var(--muted); line-height: 1.5; max-width: 32em; }
  .v-home-hero__ctas { display: flex; flex-wrap: wrap; gap: 1.75rem; margin-top: 0.5rem; align-items: center; }
  .v-home-hero__media { display: flex; align-items: center; justify-content: center; }
</style>
