---
import Verdant from "../../layouts/Verdant.astro";
import Footer from "../../components/verdant/Footer";
import GardenLive from "../../components/verdant/GardenLive.astro";
import PrivacySpectrum from "../../components/verdant/PrivacySpectrum";
import StickyProductStory from "../../components/verdant/StickyProductStory";
import StudioSection from "../../components/verdant/StudioSection.astro";
import { garden } from "../../data/verdant";
---

<Verdant title="Verdant, software grown for people">
  <section class="v-home-hero" data-v-choreograph>
    <div class="v-home-hero__stack">
      <div class="v-home-hero__eyebrow" data-v-choreo-slide data-v-choreo-delay="0">Verdant Studio. Independent software.</div>
      <h1 class="v-home-hero__headline" data-v-choreo-slide data-v-choreo-delay="0.08">Private personal finance.</h1>
      <p class="v-home-hero__sub" data-v-choreo-hold data-v-choreo-delay="0.2">Track accounts, budgets, goals, and net worth without selling your data to do it.</p>
      <div class="v-home-hero__ctas" data-v-choreo-hold data-v-choreo-delay="0.2">
        <a href={garden.url} class="v-cta v-cta--primary">Try Garden</a>
        <a href="/verdant/beta" class="v-cta">Join the beta</a>
      </div>
    </div>
    <div class="v-home-hero__media v-product-shot" data-v-choreo-scale data-v-choreo-delay="0.15">
      <GardenLive />
    </div>
  </section>

  <StickyProductStory client:only="react" />

  <section class="v-privacy-section">
    <div class="v-wrap">
      <div class="v-privacy-head">
        <p class="v-label v-label--bare">How privacy works</p>
        <h2 class="v-display">You choose your tier</h2>
        <p class="v-privacy-sub">Privacy is a spectrum. Pick the one that fits your work.</p>
      </div>
      <PrivacySpectrum client:only="react" />
    </div>
  </section>

  <StudioSection />

  <section class="v-cta-close">
    <div class="v-wrap">
      <div class="v-cta-close__content">
        <h2 class="v-display">Start with Garden</h2>
        <p class="v-cta-close__sub">Early access. No ads. No surprises.</p>
        <div class="v-cta-close__actions">
          <a href={garden.url} class="v-cta v-cta--primary">Try Garden now</a>
          <a href="/verdant/roadmap" class="v-cta">See what's next</a>
        </div>
      </div>
      <div class="v-cta-close__product">
        <GardenLive />
      </div>
    </div>
  </section>

  <Footer client:visible />
</Verdant>

<style>
  .v-home-hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 8vw, 4rem);
    align-items: center;
    padding: clamp(5.5rem, 18vw, 8rem) clamp(20px, 5vw, 56px) clamp(3rem, 10vw, 6rem);
    max-width: var(--maxw);
    margin: 0 auto;
  }
  @media (min-width: 920px) {
    .v-home-hero {
      grid-template-columns: 1.05fr 0.95fr;
      padding-top: clamp(3rem, 10vw, 6rem);
    }
  }
  .v-home-hero__stack { display: flex; flex-direction: column; gap: 1.5rem; }
  .v-home-hero__eyebrow {
    font-family: var(--font-mono); font-size: var(--text-xs);
    text-transform: uppercase; letter-spacing: 0.1em; color: var(--gold-ink);
  }
  .v-home-hero__headline { font-size: var(--display-1); color: var(--fg); line-height: 1.02; }
  .v-home-hero__sub { font-size: var(--text-lg); color: var(--muted); line-height: 1.5; max-width: 32em; }
  .v-home-hero__ctas { display: flex; flex-wrap: wrap; gap: 1.75rem; margin-top: 0.5rem; align-items: center; }
  .v-home-hero__media { display: flex; align-items: center; justify-content: center; }

  .v-privacy-section {
    padding: clamp(4rem, 10vh, 6rem) clamp(20px, 5vw, 56px);
    background: var(--paper);
  }
  .v-privacy-section .v-wrap {
    max-width: var(--maxw);
    margin: 0 auto;
  }
  .v-privacy-head {
    margin-bottom: clamp(3rem, 6vh, 4rem);
    max-width: 50ch;
  }
  .v-privacy-head .v-label {
    color: var(--gold-ink);
  }
  .v-privacy-head .v-display {
    font-size: var(--display-2);
    color: var(--ink);
    line-height: 1.18;
    margin: 0.8rem 0 1rem;
  }
  .v-privacy-sub {
    font-size: var(--text-lg);
    color: var(--ink-soft);
    line-height: 1.5;
    margin: 0;
  }

  .v-cta-close {
    padding: clamp(4rem, 10vh, 6rem) clamp(20px, 5vw, 56px);
    background: var(--paper);
  }
  .v-cta-close .v-wrap {
    max-width: var(--maxw);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2.5rem, 6vw, 6rem);
    align-items: center;
  }
  .v-cta-close__content {
    max-width: 50ch;
  }
  .v-cta-close__content .v-display {
    font-size: var(--display-2);
    color: var(--ink);
    line-height: 1.18;
    margin-bottom: 0.8rem;
  }
  .v-cta-close__sub {
    font-size: var(--text-lg);
    color: var(--ink-soft);
    line-height: 1.5;
    margin-bottom: 2rem;
  }
  .v-cta-close__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1.75rem;
    align-items: center;
  }
  .v-cta-close__product {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 860px) {
    .v-cta-close .v-wrap {
      grid-template-columns: 1fr;
    }
    .v-cta-close__product {
      order: -1;
      margin-bottom: 2rem;
    }
  }
</style>
