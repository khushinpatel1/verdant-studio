---
import Verdant from "../../layouts/Verdant.astro";
import Footer from "../../components/verdant/Footer";
---

<Verdant title="Changelog, Verdant" image="/og/og-default.png">
  <!-- ── HERO. Luminous, asymmetric. Text left, soft field right. ── -->
  <section class="ve-hero">
    <div class="ve-hero-bg" aria-hidden="true"></div>
    <div class="v-wrap ve-hero-inner">
      <p class="v-label">What's shipped</p>
      <h1 class="v-display ve-hero-head">
        What's <span style="color: var(--leaf);">shipped</span>.
      </h1>
      <p class="ve-hero-sub">
        A running log of what changed, and where we're headed.
      </p>
    </div>
  </section>

  <!-- ── NOTES TIMELINE ── -->
  <section class="ve-notes-section ve-sec">
    <div class="ve-notes-content">
      <article class="ve-note-entry" data-v-reveal>
        <h3 class="ve-note-date">2026-06-19</h3>
        <h2 class="ve-note-title">Public beta redesign live</h2>
        <p class="ve-note-text">
          Redesigned the entire site, from design tokens to navigation, footer, and brand marks. Garden's product story now front and center. New pages live: pricing (honest model), beta signup, security (with the privacy spectrum toggle), and this changelog.
        </p>
      </article>

      <article class="ve-note-entry" data-v-reveal style="--d: 0.05s;">
        <h3 class="ve-note-date">2026-06-18</h3>
        <h2 class="ve-note-title">Garden visual craft complete</h2>
        <p class="ve-note-text">
          Visual density, chart touch interactions, and swipe-dismiss sheets shipped. Year/Month in Review, period comparison, category learning loop, and Sankey cash-flow view all live in the app. The portfolio tool now shows what it can do.
        </p>
      </article>

      <article class="ve-note-entry" data-v-reveal style="--d: 0.10s;">
        <h3 class="ve-note-date">2026-06-17</h3>
        <h2 class="ve-note-title">Site type and density pass</h2>
        <p class="ve-note-text">
          Fixed headline rendering, contrast ratios, and image optimization. Added a type specimen page to settle the typography once. The site now reads clearly at every size, and every CTA launches to the live Garden app.
        </p>
      </article>

      <article class="ve-note-entry" data-v-reveal style="--d: 0.15s;">
        <h3 class="ve-note-date">2026-06-18</h3>
        <h2 class="ve-note-title">Browser back gesture in Garden</h2>
        <p class="ve-note-text">
          Implemented true OS/browser back, overlay history pops cleanly, no lost context. The app now feels native. Small change, massive quality jump.
        </p>
      </article>

      <article class="ve-note-entry" data-v-reveal style="--d: 0.20s;">
        <h3 class="ve-note-date">2026-06-17</h3>
        <h2 class="ve-note-title">Site language rewrite</h2>
        <p class="ve-note-text">
          Rewrote every page's copy, no manifesto filler, no overclaims. Lead with what the product does for you. Killed the "never leaves your device" flat line. Introduced the honest 3-tier spectrum: manual (fully local), AI import (touched once), bank link (labeled transit). Trust lives in accuracy, not promises.
        </p>
      </article>

      <article class="ve-note-entry" data-v-reveal style="--d: 0.25s;">
        <h3 class="ve-note-date">2026-06-10</h3>
        <h2 class="ve-note-title">Infrastructure: CI/CD wired</h2>
        <p class="ve-note-text">
          Garden finance app on Cloudflare Workers, build tokens re-pointed via API, CI badge green. The spine is live. Garden app at garden.khushinpatel1.workers.dev.
        </p>
      </article>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="ve-cta-section ve-sec" style="background: var(--paper-soft);">
    <h2 class="v-display ve-cta-head">Follow <span style="color: var(--leaf);">along</span>.</h2>
    <a href="mailto:verdantmail@proton.me" class="v-cta">Get updates</a>
  </section>

  <Footer client:visible />
</Verdant>

<style is:global>
  /* ── Notes section ──
     NOTE: this page predates the v3 kit and referenced a 12-col grid that no
     longer exists, so `grid-column` was a no-op and the content fell hard to
     the viewport's left edge. Pin it to the site wrap (maxw + the same
     horizontal pad as every kit section) so the margins match the rest. */
  /* beat the global `[data-skin] section { padding: … 0 }` reset (which the
     kit dodges via inner wrappers) by matching with the skin prefix too. */
  [data-skin="verdant"] .ve-notes-section,
  [data-skin="verdant"] .ve-cta-section { padding-inline: clamp(20px, 5vw, 56px); }
  .ve-notes-section { background: var(--paper-soft); padding-block: clamp(110px, 18vh, 220px); }
  .ve-notes-content { max-width: var(--maxw); margin-inline: auto; display: flex; flex-direction: column; gap: 2.8rem; }
  .ve-note-entry { padding: 1.8rem 0; border-top: 1px solid var(--line); }
  .ve-note-entry:last-child { border-bottom: 1px solid var(--line); }
  .ve-note-date { font-family: var(--font-mono); font-size: var(--text-sm); letter-spacing: 0.05em; color: var(--moss); opacity: 0.8; margin: 0 0 0.4rem 0; font-weight: 400; }
  .ve-note-title { font-family: var(--font-display); font-size: var(--text-xl); color: var(--ink); line-height: 1.3; margin: 0.4rem 0 0.8rem 0; font-weight: 400; }
  .ve-note-text { font-size: var(--text-lg); line-height: 1.7; color: var(--ink-soft); max-width: 65ch; margin: 0; }

  /* ── CTA Section ── */
  .ve-cta-section { align-content: center; }
  .ve-cta-head { max-width: var(--maxw); margin-inline: auto; font-size: var(--display-1); color: var(--ink); line-height: 1.05; }
  .ve-cta-head + .v-cta { display: inline-block; max-width: var(--maxw); margin: 2rem auto 0; }

  /* ── Responsive ── */
  @media (max-width: 860px) {
    .ve-hero-bg { display: none; }
    .ve-hero-inner { grid-column: 1 / 13; }
    .ve-notes-content { grid-column: 1 / 13; }
    .ve-cta-head, .ve-cta-head + .v-cta { grid-column: 1 / 13; }
  }
</style>
