---
import Verdant from "../../layouts/Verdant.astro";
import Footer from "../../components/verdant/Footer";
import Hero from "../../components/verdant/kit/Hero.astro";
import CTAClose1 from "../../components/verdant/kit/CTAClose1.astro";
import FAQAccordion from "../../components/verdant/FAQAccordion";
import { faq } from "../../data/verdant";

// {{KP}}: "Lifetime free beta access" / "won't be much" are public promise
// language without exact terms — legal/business sign-off needed before this
// ships as-is (audit §2 Pricing, §7 item 8). Left verbatim, not hardened.
---

<Verdant title="Pricing, Garden" description="Honest pricing. No surprises.">
  <Hero
    headline="Lifetime free beta access"
    sub="Early testers keep access forever. When we charge, it won't be much. You'll know it's coming."
    cta1={{ label: "Join the beta", href: "https://garden.khushinpatel1.workers.dev" }}
  />

  <div class="v-terms-panel">
    <div class="v-terms-panel__row">
      <span class="v-label">Now</span>
      <p>Free during the beta. No ads, no data sold. That doesn't change.</p>
    </div>
    <div class="v-terms-panel__row">
      <span class="v-label">Known</span>
      <p>You get every feature. No gatekeeping by tier. Beta testers keep free access into launch.</p>
    </div>
    <div class="v-terms-panel__row">
      <span class="v-label">Undecided</span>
      <p>{"{{KP}}"} exact post-beta pricing and what "won't be much" means in dollars. Full terms before launch.</p>
    </div>
  </div>

  <div style="padding: clamp(3rem, 8vw, 5rem) clamp(20px, 5vw, 56px); max-width: var(--maxw); margin: 0 auto;">
    <h2 style="font-size: var(--text-3xl); color: var(--fg); margin-bottom: 2rem;">Questions about pricing?</h2>
    <FAQAccordion client:visible items={faq} />
  </div>

  <CTAClose1
    headline="Try Garden free"
    sub="Beta access, forever free for early testers."
    cta={{ label: "Try Garden", href: "https://garden.khushinpatel1.workers.dev" }}
  />

  <Footer client:visible />
</Verdant>

<style>
  .v-terms-panel {
    display: flex;
    flex-direction: column;
    padding: clamp(2rem, 6vw, 3.5rem) clamp(20px, 5vw, 56px) 0;
    max-width: var(--maxw);
    margin: 0 auto;
  }
  .v-terms-panel__row {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 1.5rem;
    padding: 1.3rem 0;
    border-top: 1px solid var(--line);
    align-items: baseline;
  }
  .v-terms-panel__row p { font-size: var(--text-base); color: var(--fg); line-height: 1.6; max-width: 36em; }
  @media (max-width: 600px) {
    .v-terms-panel__row { grid-template-columns: 1fr; gap: 0.5rem; }
  }
</style>
