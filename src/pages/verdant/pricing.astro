---
import Verdant from "../../layouts/Verdant.astro";
import Footer from "../../components/verdant/Footer";
import Hero from "../../components/verdant/kit/Hero.astro";
import CardGrid from "../../components/verdant/kit/CardGrid.astro";
import Card from "../../components/verdant/kit/Card.astro";
import CTABand from "../../components/verdant/kit/CTABand.astro";
import FAQAccordion from "../../components/verdant/FAQAccordion";
import { faq } from "../../data/verdant";
---

<Verdant title="Pricing — Garden" description="Honest pricing. No surprises.">
  <Hero
    headline="Lifetime free beta access"
    sub="Early testers keep access forever. When we charge, it won't be much — and you'll know it's coming."
    cta1={{ label: "Join the beta", href: "https://garden.khushinpatel1.workers.dev" }}
  />

  <CardGrid cols={3} title="What's included">
    <Card headline="No ads ever" blurb="Garden doesn't run ads. You're the customer, not the product." />
    <Card headline="No data sold" blurb="Your numbers stay yours. We don't sell access to anyone." />
    <Card headline="All features" blurb="You get everything. No feature gatekeeping." />
  </CardGrid>

  <div style="padding: clamp(3rem, 8vw, 5rem) clamp(20px, 5vw, 56px); max-width: var(--maxw); margin: 0 auto;">
    <h2 style="font-size: var(--text-3xl); color: var(--fg); margin-bottom: 2rem;">Questions about pricing?</h2>
    <FAQAccordion client:visible items={faq} />
  </div>

  <CTABand
    headline="Try Garden free"
    sub="Beta access, forever free for early testers."
    cta={{ label: "Get started", href: "https://garden.khushinpatel1.workers.dev" }}
  />

  <Footer client:visible />
</Verdant>
