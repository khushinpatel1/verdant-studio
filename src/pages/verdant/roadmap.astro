---
import Verdant from "../../layouts/Verdant.astro";
import Footer from "../../components/verdant/Footer";
import Hero from "../../components/verdant/kit/Hero.astro";
import CTAClose1 from "../../components/verdant/kit/CTAClose1.astro";
import { ethos, garden } from "../../data/verdant";

// Status timeline. verified entries only (src/data/verdant.ts ethos.shipping).
// "Shipped" = has a concrete YYYY-MM-DD date; "Live beta" = month-precision date
// with status already Early Access; "In progress" = explicit in-progress label.
const timeline = ethos.shipping.map((item) => {
  const isDated = /^\d{4}-\d{2}-\d{2}$/.test(item.date);
  const status = item.date === "In progress" ? "In progress" : isDated ? "Shipped" : "Live beta";
  return { ...item, status };
});
---

<Verdant title="Roadmap, Garden" description="What's shipped, what's being tested, what's planned.">
  <Hero headline="Where Garden stands" sub="Built slow, on purpose. Here's exactly what's live, what's being tested, and what's next." />

  <div style="padding: clamp(2rem, 6vw, 4rem) clamp(20px, 5vw, 56px); max-width: var(--maxw); margin: 0 auto;">
    <div style="display: grid; grid-template-columns: 140px 1fr; gap: 3rem; align-items: flex-start;">
      {/* Status legend */}
      <aside style="display: flex; flex-direction: column; gap: 1.2rem; font-size: var(--text-sm); color: var(--muted); line-height: 1.6;">
        <div>
          <span style="font-family: var(--font-mono); font-size: var(--text-2xs); letter-spacing: 0.1em; text-transform: uppercase; color: var(--gold-ink); display: block; margin-bottom: 0.3rem;">Shipped</span>
          <p style="margin: 0; font-size: var(--text-xs);">Launched, verified dates</p>
        </div>
        <div>
          <span style="font-family: var(--font-mono); font-size: var(--text-2xs); letter-spacing: 0.1em; text-transform: uppercase; color: var(--gold-ink); display: block; margin-bottom: 0.3rem;">Live beta</span>
          <p style="margin: 0; font-size: var(--text-xs);">Early Access available</p>
        </div>
        <div>
          <span style="font-family: var(--font-mono); font-size: var(--text-2xs); letter-spacing: 0.1em; text-transform: uppercase; color: var(--gold-ink); display: block; margin-bottom: 0.3rem;">In progress</span>
          <p style="margin: 0; font-size: var(--text-xs);">Being built now</p>
        </div>
      </aside>

      {/* Timeline with ink accent */}
      <div style="position: relative;">
        <div style="display: flex; flex-direction: column; gap: 0; position: relative; z-index: 1;">
          {timeline.map((item) => (
            <div style="display: grid; grid-template-columns: 1fr auto; gap: 1.5rem; align-items: baseline; padding: 1.1rem 0; border-top: 1px solid var(--line);">
              <span style="font-size: var(--text-lg); color: var(--fg); font-family: var(--font-display);">
                {item.feature}
              </span>
              <span style="font-family: var(--font-mono); font-size: var(--text-xs); color: var(--muted); white-space: nowrap;">
                {item.date}
              </span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <CTAClose1
    headline="See it live"
    sub="Try Garden, or read exactly what touches a server."
    cta={{ label: "Try Garden", href: garden.url }}
    ctaSecondary={{ label: "Privacy spectrum", href: "/verdant/security#data" }}
  />

  <Footer client:visible />
</Verdant>
