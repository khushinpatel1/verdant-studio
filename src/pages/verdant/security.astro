---
import Verdant from "../../layouts/Verdant.astro";
import Footer from "../../components/verdant/Footer";
import Hero from "../../components/verdant/kit/Hero.astro";
import CardGrid from "../../components/verdant/kit/CardGrid.astro";
import Card from "../../components/verdant/kit/Card.astro";
import CTABand from "../../components/verdant/kit/CTABand.astro";
import PrivacySpectrum from "../../components/verdant/PrivacySpectrum";
import FAQAccordion from "../../components/verdant/FAQAccordion";
import { faq } from "../../data/verdant";
---

<Verdant title="Security — How Garden keeps your data private" description="The privacy guarantees, verified and explained.">
  <Hero
    headline="Security is structural"
    sub="Not by promise — by architecture. Your data is encrypted before it leaves your device. The server can't read it."
    cta1={{ label: "Try Garden", href: "https://garden.khushinpatel1.workers.dev" }}
    media={true}
    mediaSrc="/verdant/art/hero-grasses-sun.jpg"
  />

  <div id="data" style="padding: clamp(3rem, 8vw, 5rem) clamp(20px, 5vw, 56px); max-width: var(--maxw); margin: 0 auto;">
    <PrivacySpectrum client:visible />
  </div>

  <div style="padding: clamp(2rem, 6vw, 3rem) clamp(20px, 5vw, 56px); max-width: 600px; margin: 0 auto; text-align: center; font-family: var(--font-mono, monospace); color: var(--fg); line-height: 2;">
    <div>Device</div>
    <div style="color: var(--moss);">↓ encrypt</div>
    <div>Ciphertext</div>
    <div style="color: var(--moss);">↓ sync</div>
    <div>Server (stores ciphertext only — never sees your data)</div>
  </div>

  <CardGrid cols={3} title="The guarantees">
    <Card headline="Local-first encryption" blurb="Your device holds the keys. The server holds only ciphertext." />
    <Card headline="No tracking" blurb="No ads, no analytics, no third parties watching your ledger." />
    <Card headline="Offline by default" blurb="Works with no connection. Your numbers stay yours." />
  </CardGrid>

  <div style="padding: clamp(3rem, 8vw, 5rem) clamp(20px, 5vw, 56px); max-width: var(--maxw); margin: 0 auto;">
    <h2 style="font-size: var(--text-3xl); color: var(--fg); margin-bottom: 2rem;">Questions?</h2>
    <FAQAccordion client:visible items={faq} />
  </div>

  <CTABand
    headline="Security questions?"
    sub="We're transparent about how it works."
    cta={{ label: "Email us", href: "mailto:verdantmail@proton.me" }}
  />

  <Footer client:visible />
</Verdant>
