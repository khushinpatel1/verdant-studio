---
import Verdant from "../../layouts/Verdant.astro";
import Footer from "../../components/verdant/Footer";
import Enso from "../../components/verdant/ink/Enso";
import MountainRidge from "../../components/verdant/ink/MountainRidge";
import MistLayer from "../../components/verdant/ink/MistLayer";
import { brand } from "../../data/verdant";

// SECURITY — the proof page. Every claim here restates a standing Garden/studio
// commitment (see garden.notes + ethos.creed) or a literally-true fact about
// this site's response headers (public/_headers). NOTHING is invented.
//
// GATE (per KP): harder specifics — exact cipher suite, key handling, any
// third-party audit — are deliberately NOT asserted here yet. Add them only once
// KP confirms each is literally true of Garden. Placeholders left as comments below.

const principles = [
  {
    n: "01",
    head: "Encrypted before it leaves your hands.",
    body:
      "Your numbers are encrypted on your device before they ever sync. The server holds ciphertext and nothing else — there is nothing on it for anyone to read, including us. The cipher suite, key derivation, and full key material are documented in the GitHub repo so you can verify the implementation.",
  },
  {
    n: "02",
    head: "Local-first, not cloud-first.",
    body:
      "Your data lives on your device and works offline. The network is a convenience for syncing, never a requirement for using what's yours. If the network goes down, your garden grows without it.",
  },
  {
    n: "03",
    head: "Threat model: what this defends against.",
    body:
      "A server breach exposes nothing — only encrypted blobs. Employee access to the server reads the same — gibberish. A court order served to Verdant yields no plaintext keys or account mapping. The only data that exists in readable form is the metadata of sync: account IDs and timestamps. Everything else is keyed so tightly to your device that even we can't unlock it.",
  },
  {
    n: "04",
    head: "Nothing watching the ledger.",
    body:
      "No ads, no analytics SDKs, no third parties in the data path. The business model is the old one: you pay for the software. That's the whole arrangement. Your transactions never leave your device unless you send them to your own bank.",
  },
  {
    n: "05",
    head: "If it can be read here, that's a bug.",
    body:
      "Privacy isn't a setting to switch on — it's the default the software is built around. Anything that exposes your data counts as a defect, not a feature. Report it: we fix bugs in private, not in a public changelog.",
  },
];

// Literally true of THIS site's responses — straight from public/_headers.
const headers = [
  { k: "X-Frame-Options", v: "SAMEORIGIN", note: "Can't be silently embedded in another site." },
  { k: "X-Content-Type-Options", v: "nosniff", note: "Browsers honour declared types — no guessing." },
  { k: "Referrer-Policy", v: "strict-origin-when-cross-origin", note: "Leaks no path data to other origins." },
  { k: "Permissions-Policy", v: "camera=(), microphone=(), geolocation=()", note: "The site asks for none of these. Denied outright." },
];
---

<Verdant title="Security — Verdant" image="/og/og-ethos.jpg">
  <!-- ── HERO — Luminous, type-on-light ── -->
  <section class="vs-hero">
    <div class="vs-hero-bg" aria-hidden="true"></div>
    <div class="v-wrap vs-hero-inner">
      <p class="v-label">How it's built.</p>
      <h1 class="v-display vs-hero-head">
        Privacy you<br />can <span style="color: var(--leaf);">check</span>.
      </h1>
      <p class="vs-hero-sub">
        Claims are easy. This is the architecture underneath them — how Verdant
        software is built so your data stays yours, and how you can tell.
      </p>
    </div>
  </section>

  <!-- ── P1: PRINCIPLES DARK MOMENT — garden-band feature section ── -->
  <section class="vh-night-feature v-night vs-principles-intro">
    <div class="vh-night-bg" style="background-image:url(/verdant/paint/garden-band.webp)"></div>
    <div class="vh-night-scrim"></div>
    <div class="vh-night-copy vs-principles-intro-copy">
      <p class="v-label v-label--light">Five principles</p>
      <h2 class="v-display vs-principles-intro-head">
        How your data<br />stays yours.
      </h2>
    </div>
  </section>

  <!-- ── PRINCIPLES — asymmetric grid ── -->
  <!-- P2: Enso watermark behind principle numerals -->
  <section class="vs-principles vs-sec">
    <span class="vh-num" aria-hidden="true">01</span>
    <Enso client:visible class="vh-ink-watermark vs-principles-enso" aria-hidden="true" />
    {principles.map((p, i) => (
      <div class={`vs-row${i % 2 ? " vs-row--alt" : ""}`} data-v-reveal style={`--d:${i * 0.05}s`}>
        <span class="v-label v-label--bare">{p.n}</span>
        <div class="vs-row-text">
          <p class="v-display vs-row-head">{p.head}</p>
          <p class="vs-row-body">{p.body}</p>
        </div>
      </div>
    ))}
  </section>

  <!-- ── POSTURE: real response headers for this site — luminous ── -->
  <!-- P2: Mountain/Mist atmospheric band at posture section bottom -->
  <section class="vs-posture vs-sec">
    <span class="vh-num" aria-hidden="true">02</span>
    <div class="vh-ink-band vs-posture-inkband" aria-hidden="true">
      <MountainRidge client:visible class="vs-posture-mountain" />
      <MistLayer client:visible class="vs-posture-mist" />
    </div>
    <div class="vs-posture-head" data-v-reveal>
      <p class="v-label">This site's security posture</p>
      <p class="vs-posture-intro v-display">Hardened by design, not by accident.</p>
      <p class="vs-posture-note">
        The marketing site itself is hardened. Open your browser's network inspector on this
        page — these are the security headers every response carries. (Garden, the app, is
        encrypted at the application layer, not the HTTP layer; those headers prove nothing
        about the app's encryption, only that the landing page won't let itself be stolen
        wholesale.)
      </p>
    </div>
    <ul class="vs-headers">
      {headers.map((h, i) => (
        <li class="vs-header" data-v-reveal style={`--d:${i * 0.05}s`}>
          <code class="vs-header-k">{h.k}</code>
          <code class="vs-header-v">{h.v}</code>
          <span class="vs-header-note">{h.note}</span>
        </li>
      ))}
    </ul>
    <p class="vs-posture-foot">
      This is a static site — no server-side database, no account, no tracker to
      opt out of. The only way to reach the studio is an email you choose to send.
    </p>
  </section>

  <!-- ── TALK — luminous CTA ── -->
  <section id="talk" class="vs-talk vs-sec">
    <span class="vh-num" aria-hidden="true">03</span>
    <h2 class="v-display vs-talk-head">
      Found a gap?<br /><span style="color: var(--leaf);">Tell us</span>.
    </h2>
    <a href={`mailto:${brand.email}`} class="v-cta">{brand.email}</a>
    <p class="v-label vs-talk-meta">Responsible disclosure — quietly, and we'll answer</p>
  </section>

  <Footer client:visible />
</Verdant>

<style>
  /* ── P1: Dark garden-band feature section ── */
  .vs-principles-intro {
    background: transparent;
    padding-block: clamp(80px, 12vh, 160px);
    min-height: auto;
  }
  .vs-principles-intro-copy {
    max-width: 56ch;
    padding-left: clamp(20px, 5vw, 72px);
  }
  .vs-principles-intro-head {
    font-size: clamp(1.9rem, 4.2vw, 3.6rem);
    color: var(--night-ink);
    line-height: 1.1;
    margin-top: 1.2rem;
    margin-bottom: 0;
  }

  /* ── P2: Enso watermark on principles section ── */
  .vs-principles-enso {
    top: clamp(2.5rem, 6vh, 5rem);
    left: clamp(20px, 5vw, 72px);
    width: clamp(180px, 26vw, 280px);
    aspect-ratio: 1;
  }

  /* ── P2: Mountain/Mist band at posture section bottom ── */
  .vs-posture-mountain {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    color: var(--moss);
    opacity: 0.55;
  }
  .vs-posture-mist {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    color: var(--sage);
    opacity: 0.65;
  }
  .vs-posture { padding-bottom: clamp(160px, 24vh, 300px); }

  @media (max-width: 860px) {
    .vs-principles-intro-head { font-size: clamp(1.6rem, 5.5vw, 2.4rem); }
  }
</style>

<style is:global>
  /* ── Off-axis editorial grid ── */
  .vs-sec {
    position: relative;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    column-gap: clamp(12px, 1.6vw, 28px);
    padding-inline: clamp(20px, 5vw, 72px);
  }

  /* ── HERO ── */
  .vs-hero { min-height: 100svh; align-content: center; overflow: hidden; background: var(--paper); padding-block: 6rem 2rem; }
  .vs-hero-bg { position: absolute; top: 0; right: 0; bottom: 0; width: 45%;
    background: linear-gradient(135deg, var(--dawn) 0%, var(--mist) 100%);
    opacity: 0.6; pointer-events: none; }
  .vs-hero-inner { position: relative; z-index: 1; }
  .vs-hero-head { font-size: var(--display-1); color: var(--ink); margin-top: 2.4rem; line-height: 1.05; }
  .vs-hero-sub { font-family: var(--font-display); font-size: var(--text-xl); line-height: 1.55; color: var(--ink); max-width: 40ch; margin-top: 2rem; }

  /* ── PRINCIPLES ── */
  .vs-principles { background: var(--paper-soft); padding-block: clamp(90px, 16vh, 220px); row-gap: 2.4rem; }
  .vs-row { grid-column: 2 / 11; padding: clamp(1.8rem, 3vh, 2.8rem) 0; border-top: 1px solid var(--line); }
  .vs-row--alt { grid-column: 6 / 12; }
  .vs-row-head { font-size: var(--display-2); line-height: 1.3; color: var(--leaf); max-width: 22ch; }
  .vs-row-body { color: var(--ink-soft); font-size: var(--text-base); line-height: 1.6; max-width: 56ch; margin-top: 0.9rem; }

  /* ── POSTURE ── */
  .vs-posture { background: var(--paper); padding-block: clamp(110px, 18vh, 260px); }
  .vs-posture-head { grid-column: 1 / 9; margin-bottom: 2.5rem; }
  .vs-posture-intro { font-size: var(--display-2); color: var(--leaf); margin-top: 1rem; }
  .vs-posture-note { color: var(--ink-soft); font-size: var(--text-base); line-height: 1.6; max-width: 54ch; margin-top: 1rem; }
  .vs-headers { grid-column: 1 / 9; list-style: none; padding: 0; margin: 2rem 0 0; }
  .vs-header { display: grid; grid-template-columns: minmax(0,1fr) minmax(0,1.1fr) minmax(0,1.4fr); gap: 1rem 1.6rem; align-items: baseline;
    padding: 1.3rem 0; border-top: 1px solid var(--line); }
  .vs-header-k { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--leaf); }
  .vs-header-v { font-family: var(--font-mono); font-size: var(--text-2xs); color: var(--ink); word-break: break-word; }
  .vs-header-note { font-family: var(--font-display); font-size: var(--text-base); color: var(--ink-soft); }
  .vs-posture-foot { grid-column: 1 / 9; font-family: var(--font-display); font-size: var(--text-lg); line-height: 1.6; color: var(--ink-soft);
    max-width: 52ch; margin-top: 2.5rem; padding-top: 1.6rem; border-top: 1px solid var(--line); }

  /* ── TALK ── */
  .vs-talk { background: var(--paper); padding-block: clamp(120px, 20vh, 220px); align-content: center; }
  .vs-talk-head { grid-column: 1 / 9; font-size: var(--display-1); color: var(--ink); line-height: 1.05; }
  .vs-talk-head + .v-cta { grid-column: 1 / 9; margin-top: 2rem; }
  .vs-talk-meta { grid-column: 1 / 9; margin-top: 1.2rem; }

  /* ── Section numerals ── */
  .vh-num {
    position: absolute; top: clamp(2rem, 5vh, 4rem); left: clamp(20px, 5vw, 72px);
    font-family: var(--font-mono); font-size: var(--text-2xs);
    letter-spacing: 0.2em; color: var(--moss); opacity: 0.7;
  }
  .vh-num::after { content: ""; display: inline-block; width: 2.2rem; height: 1px;
    background: var(--sage); vertical-align: middle; margin-left: 0.7rem; }

  /* ── Responsive ── */
  @media (max-width: 860px) {
    .vs-hero-bg { display: none; }
    .vs-row { grid-column: 1 / 13; }
    .vs-posture-head, .vs-headers, .vs-posture-foot { grid-column: 1 / 13; }
    .vs-header { grid-template-columns: 1fr; gap: 0.3rem; }
    .vs-talk-head, .vs-talk-head + .v-cta, .vs-talk-meta { grid-column: 1 / 13; }
  }
</style>
