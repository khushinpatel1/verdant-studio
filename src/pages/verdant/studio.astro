---
import Verdant from "../../layouts/Verdant.astro";
import Footer from "../../components/verdant/Footer";
import Hero from "../../components/verdant/kit/Hero.astro";
import FeatureRow from "../../components/verdant/kit/FeatureRow.astro";
import CardGrid from "../../components/verdant/kit/CardGrid.astro";
import Card from "../../components/verdant/kit/Card.astro";
import CTABand from "../../components/verdant/kit/CTABand.astro";
import { team } from "../../data/verdant";
---

<Verdant title="Verdant Studio — The team" description="A small studio building software for people, not advertisers.">
  <Hero
    headline="Verdant Studio"
    sub="A small, independent team building privacy-first software. One project finished. The next one in the soil."
    cta1={{ label: "Explore Garden", href: "/verdant/garden" }}
  />

  <FeatureRow
    align="left"
    headline="How we work"
    body="Small team, big vision. We move slow, think hard, and ship when it's ready. No deadlines driven by funding. No features driven by ads."
    media={true}
    mediaSrc="/verdant/art/hero-grasses-sun.jpg"
  />

  <FeatureRow
    align="right"
    headline="What we believe"
    body="Software should respect you. It shouldn't watch you, judge you, or sell you. That's structural — built into every line of code."
    media={true}
    mediaSrc="/verdant/art/ethos-sand.jpg"
  />

  <CardGrid cols={3} title="The team">
    {team.map((person) => (
      <Card
        headline={person.name}
        blurb={`${person.role} · ${person.since}`}
        link={{ label: "Profile", href: `/verdant/team/${person.slug}` }}
      />
    ))}
  </CardGrid>

  <CTABand
    headline="Work with us"
    sub="We're always looking for great people to join."
    cta={{ label: "Get in touch", href: "mailto:verdantmail@proton.me" }}
  />

  <Footer client:visible />
</Verdant>
