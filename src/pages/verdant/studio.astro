---
import Verdant from "../../layouts/Verdant.astro";
import Footer from "../../components/verdant/Footer";
import Hero from "../../components/verdant/kit/Hero.astro";
import CTABand from "../../components/verdant/kit/CTABand.astro";
import { studio, brand } from "../../data/verdant";
---

<Verdant title="Verdant Studio — Studio of one" description="An independent software studio, deliberately small.">
  <Hero
    headline="Verdant Studio"
    sub={studio.lead}
    cta1={{ label: "Explore Garden", href: "/verdant/garden" }}
  />

  <div style="padding: clamp(3rem, 8vw, 5rem) clamp(20px, 5vw, 56px); max-width: var(--maxw); margin: 0 auto;">
    <p style="font-family: var(--font-display); font-size: var(--text-2xl); color: var(--fg); max-width: 30em; margin-bottom: 2.5rem;">
      {studio.who}
    </p>
    <div style="display: grid; gap: 1.75rem; max-width: 36em;">
      {studio.lines.map((line) => (
        <p style="border-top: 1px solid var(--line); padding-top: 1.25rem; font-size: var(--text-base); line-height: 1.7; color: var(--muted);">
          {line}
        </p>
      ))}
    </div>
  </div>

  <CTABand
    headline="Follow the work"
    sub="Questions, feedback, or just want to say hello?"
    cta={{ label: "Get in touch", href: `mailto:${brand.email}` }}
  />

  <Footer client:visible />
</Verdant>
