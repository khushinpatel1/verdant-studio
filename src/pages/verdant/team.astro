---
import Verdant from "../../layouts/Verdant.astro";
import TextReveal from "../../components/verdant/TextReveal";
import Footer from "../../components/verdant/Footer";
import { studio } from "../../data/verdant";
---

<Verdant title="People — Verdant" image="/og/og-team.jpg">
  <!-- ── HERO ── -->
  <section class="vt-hero">
    <div class="v-wrap">
      <div>
        <p class="v-label">The gardeners</p>
        <TextReveal
          client:load
          as="h1"
          className="v-display vt-hero-head"
          lines={["Small, on purpose.", "No %account managers%."]}
        />
        <p class="vt-hero-sub v-display">
          Right now, one. No layer between you and the person doing the work — and
          no invented roster pretending otherwise.
        </p>
      </div>
    </div>
    <div class="v-print-field vt-hero-art" data-v-parallax="0.07" aria-hidden="true">
      <img src="/verdant/art/team-flower.jpg" alt="" fetchpriority="high" />
    </div>
  </section>

  <!-- ── WHO ── an honest statement, not a fake roster ── -->
  <section class="vt-roster">
    <div class="v-wrap vt-who">
      <h2 class="v-display vt-who-name" data-v-reveal>{studio.who}</h2>
      <p class="vt-who-lead v-display" data-v-reveal>{studio.lead}</p>
      {studio.lines.map((line, i) => (
        <p class="vt-who-line" data-v-reveal style={`--d:${i * 0.06}s`}>{line}</p>
      ))}
    </div>
  </section>

  <!-- ── closing ── -->
  <section class="vt-end">
    <div class="v-wrap vt-end-inner">
      <p class="v-display vt-end-line" data-v-reveal>The door is open.</p>
      <a href="/verdant/ethos#talk" class="v-cta" data-cursor="Write">Say hello</a>
    </div>
  </section>

  <Footer client:visible />
</Verdant>

<style is:global>
  .vt-hero { padding-top: 11rem; position: relative; overflow: hidden;
    min-height: 92svh; display: flex; flex-direction: column; justify-content: center; }
  .vt-hero > .v-wrap { position: relative; z-index: 1; }
  /* dark studio painting — no blend (multiply would erase the white camellia).
     Pinned off the right viewport edge with a directional fade, so the night
     wash rolls in from outside the page instead of floating as an island. */
  .vt-hero-art {
    --pf-blend: normal;
    --pf-opacity: 0.92;
    --pf-w: clamp(720px, 66vw, 980px);
    --pf-right: -14vw;
    --pf-y: 50%;
    /* ellipse pinned past the img's right edge: solid where it meets the
       viewport edge, feathered into cream on left / top / bottom */
    --pf-mask: radial-gradient(ellipse 78% 60% at 82% 50%, #000 36%, transparent 76%);
  }
  @media (max-width: 800px) {
    .vt-hero-art {
      --pf-w: clamp(440px, 130vw, 560px);
      --pf-right: -34vw;
      --pf-y: 86%;
      --pf-opacity: 0.8;
      --pf-mask: radial-gradient(ellipse 70% 56% at 76% 54%, #000 30%, transparent 72%);
    }
  }
  .vt-hero-head { font-size: var(--display-1); color: var(--forest-900); }
  .vt-hero-sub { font-size: var(--display-2); color: var(--terra); max-width: 40ch; margin-top: 2rem; }

  .vt-who { max-width: 54rem; }
  .vt-who-name { font-size: var(--display-2); color: var(--green); line-height: 1.12; }
  .vt-who-lead { font-size: var(--text-xl); color: var(--gold); margin: 1.2rem 0 2.4rem; }
  .vt-who-line { font-family: var(--font-display); font-size: var(--text-lg); color: var(--terra);
    line-height: 1.7; max-width: 52ch; margin-bottom: 1.4rem; }

  .vt-roster { display: flex; flex-direction: column; }
  .vt-row { display: grid; grid-template-columns: auto 1fr auto; gap: clamp(1.5rem, 4vw, 4rem); align-items: baseline;
    padding: clamp(2.5rem, 6vh, 4.5rem) 0; border-top: 1px solid var(--line); color: inherit;
    transition: padding-left .4s var(--ease); }
  .vt-row:hover { padding-left: 1.2rem; }
  .vt-row-n { font-size: var(--display-2); color: var(--moss); line-height: 1; }
  .vt-row-name { font-size: var(--display-1); color: var(--green); margin: 0.6rem 0 0.8rem; transition: color .3s; }
  .vt-row:hover .vt-row-name { color: var(--gold); }
  .vt-row-short { font-family: var(--font-display); font-size: var(--text-xl); color: var(--terra); max-width: 46ch; }
  .vt-row-meet { align-self: center; white-space: nowrap; }
  @media (max-width: 720px) { .vt-row { grid-template-columns: auto 1fr; } .vt-row-meet { display: none; } }

  .vt-end-inner { display: flex; flex-direction: column; align-items: flex-start; gap: 1.4rem; }
  .vt-end-line { font-size: var(--display-2); color: var(--green); }
</style>
