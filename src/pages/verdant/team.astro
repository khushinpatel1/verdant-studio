---
import Verdant from "../../layouts/Verdant.astro";
import Footer from "../../components/verdant/Footer";
import Moon from "../../components/verdant/ink/Moon";
import BlossomBranch from "../../components/verdant/ink/BlossomBranch";
import PetalFall from "../../components/verdant/ink/PetalFall";
import { studio } from "../../data/verdant";
---

<Verdant title="People — Verdant" image="/og/og-team.jpg">
  <!-- ── HERO — luminous, asymmetric ── -->
  <!-- P2: PetalFall subtle overlay on the hero -->
  <section class="vt-hero">
    <div class="vt-hero-bg" aria-hidden="true"></div>
    <PetalFall client:visible className="vt-hero-petal" aria-hidden="true" />
    <div class="v-wrap vt-hero-inner">
      <p class="v-label">The gardeners</p>
      <h1 class="v-display vt-hero-head">
        Small, on purpose.<br />No <span style="color: var(--leaf);">account managers</span>.
      </h1>
      <p class="vt-hero-sub">
        Right now, one. No layer between you and the person doing the work — and
        no invented roster pretending otherwise.
      </p>
    </div>
  </section>

  <!-- ── WHO ── an honest statement, not a fake roster ── -->
  <!-- P3: BlossomBranch beside the roster statement -->
  <section class="vt-roster">
    <div class="v-wrap vt-who">
      <h2 class="v-display vt-who-name" data-v-reveal>{studio.who}</h2>
      <BlossomBranch client:visible side="right" className="vh-leaf-accent vt-who-blossom" aria-hidden="true" />
      <p class="vt-who-lead v-display" data-v-reveal>{studio.lead}</p>
      {studio.lines.map((line, i) => (
        <p class="vt-who-line" data-v-reveal style={`--d:${i * 0.06}s`}>{line}</p>
      ))}
    </div>
  </section>

  <!-- ── CLOSING ── -->
  <!-- P1: Moonlit garden behind the closing invitation -->
  <section class="vh-night-feature v-night vt-end">
    <div class="vh-night-bg" style="background-image:url(/verdant/paint/moonlit-garden.webp)"></div>
    <div class="vh-night-scrim"></div>
    <Moon client:visible className="vh-night-moon" />
    <div class="vh-night-copy vt-end-inner">
      <p class="v-display vt-end-line" data-v-reveal>The door is <span style="color: var(--leaf);">open</span>.</p>
      <a href="/verdant/ethos#talk" class="v-cta">Say hello</a>
    </div>
  </section>

  <Footer client:visible />
</Verdant>

<style is:global>
  /* ── HERO ── */
  .vt-hero { min-height: 100svh; align-content: center; overflow: hidden; background: var(--paper); padding-block: 6rem 2rem; }
  .vt-hero-bg { position: absolute; top: 0; right: 0; bottom: 0; width: 45%;
    background: linear-gradient(135deg, var(--dawn) 0%, var(--mist) 100%);
    opacity: 0.6; pointer-events: none; }
  .vt-hero-inner { position: relative; z-index: 1; max-width: 52ch; }
  .vt-hero-head { font-size: var(--display-1); color: var(--ink); margin-top: 2.4rem; line-height: 1.05; }
  .vt-hero-sub { font-family: var(--font-display); font-size: var(--text-xl); line-height: 1.55; color: var(--ink); max-width: 38ch; margin-top: 2rem; }

  /* ── WHO ── */
  .vt-roster { background: var(--paper-soft); padding-block: clamp(110px, 18vh, 260px); }
  .vt-who { max-width: 54rem; }
  .vt-who-name { font-size: var(--display-2); color: var(--leaf); line-height: 1.12; }
  .vt-who-lead { font-size: var(--text-xl); color: var(--leaf); margin: 1.2rem 0 2.4rem; }
  .vt-who-line { font-family: var(--font-display); font-size: var(--text-lg); color: var(--ink-soft);
    line-height: 1.6; max-width: 52ch; margin-bottom: 1.4rem; }

  /* ── END ── */
  .vt-end { background: var(--paper); padding-block: clamp(110px, 18vh, 260px); }
  .vt-end-inner { display: flex; flex-direction: column; align-items: flex-start; gap: 1.4rem; }
  .vt-end-line { font-size: var(--display-2); color: var(--ink); }

  /* ── P2: PetalFall subtle overlay on hero ── */
  .vt-hero-petal {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    max-width: 900px;
    height: 100%;
    max-height: 600px;
    opacity: 0.18;
    pointer-events: none;
    z-index: 0;
  }

  /* ── P3: BlossomBranch beside roster statement ── */
  .vt-who-blossom {
    position: absolute;
    right: -12%;
    top: 8%;
    width: 28%;
    opacity: 0.7;
  }

  /* ── P1: Moonlit manifesto closing ── */
  .vt-end {
    /* Override .v-night background so the painted image shows through */
    background: transparent;
    padding-block: clamp(120px, 20vh, 220px);
    min-height: 520px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }
  .vt-end-inner {
    max-width: 56ch;
    padding-left: clamp(0px, 2vw, 32px);
    z-index: 2;
  }
  .vt-end-line {
    font-size: clamp(1.9rem, 4.2vw, 3.6rem);
    color: var(--night-ink);
    line-height: 1.1;
    margin-bottom: 1.6rem;
  }
  .vt-end .v-cta {
    color: var(--night-gold);
  }

  /* ── Responsive ── */
  @media (max-width: 800px) {
    .vt-hero-bg { display: none; }
    .vt-who-blossom { display: none; }
    .vt-end-line { font-size: clamp(1.6rem, 5.5vw, 2.4rem); }
  }
</style>
