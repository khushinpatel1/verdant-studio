---
import Verdant from "../../../layouts/Verdant.astro";
import InkGrowth from "../../../components/verdant/InkGrowth";
import Footer from "../../../components/verdant/Footer";
import { team } from "../../../data/verdant";

export async function getStaticPaths() {
  return team.map((person, i) => ({
    params: { slug: person.slug },
    props: {
      person,
      prev: team[(i - 1 + team.length) % team.length],
      next: team[(i + 1) % team.length],
    },
  }));
}

const { person, prev, next } = Astro.props;
---

<Verdant title={`${person.name} — Verdant`}>
  <section class="vp">
    <div class="v-wrap">
      <a href="/verdant/team" class="v-label vp-back" data-cursor="Back">← People</a>

      <div class="vp-grid">
        <div class="vp-aside">
          <span class="v-organic vp-initial">{person.name.charAt(0)}</span>
          <InkGrowth client:visible side="left" className="vp-vine" />
        </div>

        <div class="vp-text">
          <h1 class="v-display vp-name">{person.name}</h1>
          <p class="v-label v-label--bare vp-role">{person.role} · Since {person.since}</p>
          <div class="vp-bio">
            {person.bio.map((para) => <p>{para}</p>)}
          </div>
          <p class="vp-cares">Cares for — {person.cares}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="vp-nav">
    <div class="v-wrap vp-nav-row">
      <a href={`/verdant/team/${prev.slug}`} class="vp-nav-link" data-cursor="Meet">
        <span class="v-label v-label--bare">← Previous</span>
        <span class="v-display vp-nav-name">{prev.name}</span>
        <span class="vp-nav-role">{prev.role}</span>
      </a>
      <a href={`/verdant/team/${next.slug}`} class="vp-nav-link vp-nav-link--r" data-cursor="Meet">
        <span class="v-label v-label--bare">Next →</span>
        <span class="v-display vp-nav-name">{next.name}</span>
        <span class="vp-nav-role">{next.role}</span>
      </a>
    </div>
  </section>

  <Footer client:visible />
</Verdant>

<style is:global>
  .vp { padding-top: 9rem; }
  .vp-back { margin-bottom: 3rem; }
  .vp-grid { display: grid; grid-template-columns: 0.7fr 1.3fr; gap: clamp(2.5rem, 6vw, 6rem); align-items: start; }
  .vp-aside { position: relative; min-height: 320px; }
  .vp-initial { display: block; font-size: clamp(8rem, 20vw, 16rem); line-height: 0.8; color: var(--sage); }
  .vp-vine { position: absolute; left: 10%; top: 18%; width: 120px; height: 360px; }
  @media (max-width: 820px) { .vp-aside { min-height: 0; } }
  .vp-name { font-size: clamp(3rem, 7vw, 6rem); color: var(--green); line-height: 0.96; }
  .vp-role { margin: 1.2rem 0 2.4rem; color: var(--clay); }
  .vp-bio { display: flex; flex-direction: column; gap: 1.4rem; max-width: 58ch; }
  .vp-bio p { font-family: var(--font-display); font-size: clamp(1.2rem, 1.8vw, 1.55rem); line-height: 1.55; color: #3a4a28; }
  .vp-cares { font-family: var(--font-mono); font-size: 0.78rem; letter-spacing: 0.06em; color: var(--gold); margin-top: 2.4rem;
    padding-top: 1.4rem; border-top: 1px solid var(--line); }
  @media (max-width: 820px) { .vp-grid { grid-template-columns: 1fr; } .vp-vine { display: none; } }

  .vp-nav-row { display: flex; justify-content: space-between; gap: 2rem; padding-top: 2.5rem; border-top: 1px solid var(--line); }
  .vp-nav-link { display: flex; flex-direction: column; gap: 0.4rem; }
  .vp-nav-link--r { text-align: right; align-items: flex-end; }
  .vp-nav-name { font-size: clamp(1.6rem, 3vw, 2.4rem); color: var(--green); transition: color .3s; }
  .vp-nav-link:hover .vp-nav-name { color: var(--gold); }
  .vp-nav-role { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--clay); }
</style>
